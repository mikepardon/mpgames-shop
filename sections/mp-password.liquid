{%- comment -%}
  MPGames password / "opening soon" splash. Self-contained (the password
  layout does not load mp-header), so it loads its own fonts. Includes the
  real Shopify newsletter (`customer`) and store-entry (`storefront_password`) forms.
{%- endcomment -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700&family=Barlow+Semi+Condensed:wght@500;600;700&display=swap" rel="stylesheet">

{%- style -%}
  .mp-pw-{{ section.id }} { --amber: #f2872f; min-height: 100vh; display: flex; align-items: center; justify-content: center;
    background: radial-gradient(120% 120% at 50% 0%, #1d4252 0%, #16323f 45%, #0d2630 100%);
    font-family: 'Barlow', ui-sans-serif, system-ui, sans-serif; color: #fff; padding: 40px 20px; box-sizing: border-box; }
  .mp-pw-{{ section.id }} .pw__cond { font-family: 'Barlow Semi Condensed', ui-sans-serif, sans-serif; }
  .mp-pw-{{ section.id }} .pw__inner { width: 100%; max-width: 520px; text-align: center; }
  .mp-pw-{{ section.id }} .pw__logo { height: 44px; width: auto; margin: 0 auto 30px; display: block; }
  .mp-pw-{{ section.id }} .pw__badge { display: inline-block; font-size: 12px; font-weight: 700; letter-spacing: .8px; text-transform: uppercase; color: #ffd2b0; background: rgba(242,135,47,.16); border: 1px solid rgba(242,135,47,.4); border-radius: 30px; padding: 6px 15px; }
  .mp-pw-{{ section.id }} .pw__h { font-size: 40px; font-weight: 700; line-height: 1.1; margin: 20px 0 12px; }
  .mp-pw-{{ section.id }} .pw__sub { font-size: 15.5px; line-height: 1.6; color: #9fb4bd; max-width: 400px; margin: 0 auto; }
  .mp-pw-{{ section.id }} .pw__card { background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.12); border-radius: 14px; padding: 24px 26px; margin-top: 28px; }
  .mp-pw-{{ section.id }} .pw__cardlabel { font-size: 12.5px; font-weight: 600; color: #cfe0e6; margin-bottom: 12px; }
  .mp-pw-{{ section.id }} .pw__form { display: flex; gap: 8px; }
  .mp-pw-{{ section.id }} .pw__form input { flex: 1; min-width: 0; box-sizing: border-box; border: 1px solid rgba(255,255,255,.2); border-radius: 8px; padding: 12px 14px; font-size: 14px; background: rgba(255,255,255,.95); color: #16323f; font-family: inherit; }
  .mp-pw-{{ section.id }} .pw__form button { flex: none; background: var(--amber); color: #fff; border: 0; border-radius: 8px; padding: 12px 20px; font-size: 14px; font-weight: 700; cursor: pointer; font-family: inherit; white-space: nowrap; }
  .mp-pw-{{ section.id }} .pw__ok { background: rgba(95,191,126,.16); border: 1px solid rgba(95,191,126,.5); color: #c7f0d6; border-radius: 8px; padding: 10px 13px; font-size: 13px; margin-bottom: 12px; }
  .mp-pw-{{ section.id }} .pw__err { background: rgba(214,64,46,.16); border: 1px solid rgba(214,64,46,.5); color: #ffd2ca; border-radius: 8px; padding: 10px 13px; font-size: 13px; margin-bottom: 12px; }
  .mp-pw-{{ section.id }} .pw__enter { margin-top: 26px; }
  .mp-pw-{{ section.id }} .pw__enterbtn { background: none; border: 0; color: #9fb4bd; font-size: 13px; font-weight: 600; cursor: pointer; font-family: inherit; text-decoration: underline; }
  .mp-pw-{{ section.id }} .pw__pwform { max-width: 340px; margin: 14px auto 0; }
  .mp-pw-{{ section.id }} [hidden] { display: none; }
  .mp-pw-{{ section.id }} .pw__foot { margin-top: 34px; font-size: 12px; color: #6f8892; }
  @media (max-width: 600px) {
    .mp-pw-{{ section.id }} .pw__h { font-size: 32px; }
    .mp-pw-{{ section.id }} .pw__form { flex-direction: column; }
  }
{%- endstyle -%}

<div class="mp-pw-{{ section.id }}">
  <div class="pw__inner">
    <img class="pw__logo" src="{{ 'MPGames-logo.png' | asset_url }}" alt="{{ shop.name | escape }}" width="200" height="44">
    <span class="pw__badge pw__cond">{{ section.settings.badge | default: 'Opening soon' }}</span>
    <h1 class="pw__h pw__cond">{{ section.settings.heading | default: 'Games worth gathering for' }}</h1>
    <p class="pw__sub">{{ section.settings.subtext | default: "We're putting the finishing touches to the shop. Leave your email and we'll tell you the moment the doors open." }}</p>

    <div class="pw__card">
      <div class="pw__cardlabel">{{ section.settings.form_label | default: 'Get launch-day access' }}</div>
      {%- form 'customer' -%}
        {%- if form.posted_successfully? -%}
          <div class="pw__ok">Thanks — you're on the list. We'll be in touch soon.</div>
        {%- elsif form.errors -%}
          <div class="pw__err">{{ form.errors.translated_fields.email | default: 'Email' }} {{ form.errors.messages.email | default: 'is invalid.' }}</div>
        {%- endif -%}
        <input type="hidden" name="contact[tags]" value="newsletter, opening-soon">
        <div class="pw__form">
          <input type="email" name="contact[email]" autocomplete="email" placeholder="you@example.com" aria-label="Email" required>
          <button type="submit" class="pw__cond">Notify me</button>
        </div>
      {%- endform -%}
    </div>

    <div class="pw__enter">
      <button type="button" class="pw__enterbtn" data-pw-toggle aria-expanded="false">Have the password? Enter the store</button>
      <div class="pw__pwform" data-pw-panel hidden>
        {%- form 'storefront_password' -%}
          {%- if form.errors -%}
            <div class="pw__err">Incorrect password — please try again.</div>
            <script>document.currentScript.closest('[data-pw-panel]').removeAttribute('hidden');</script>
          {%- endif -%}
          <div class="pw__form">
            <input type="password" name="password" autocomplete="current-password" placeholder="Store password" aria-label="Store password" required>
            <button type="submit" class="pw__cond">Enter</button>
          </div>
        {%- endform -%}
      </div>
    </div>

    <div class="pw__foot">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}{% if section.settings.footer_note != blank %} · {{ section.settings.footer_note }}{% endif %}</div>
  </div>
</div>

<script>
  (function () {
    var root = document.querySelector('.mp-pw-{{ section.id }}');
    if (!root) return;
    var btn = root.querySelector('[data-pw-toggle]');
    var panel = root.querySelector('[data-pw-panel]');
    btn.addEventListener('click', function () {
      var open = panel.hasAttribute('hidden');
      if (open) { panel.removeAttribute('hidden'); } else { panel.setAttribute('hidden', ''); }
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      if (open) { var i = panel.querySelector('input'); if (i) i.focus(); }
    });
  })();
</script>

{% schema %}
{
  "name": "MP Password",
  "settings": [
    { "type": "text", "id": "badge", "label": "Badge", "default": "Opening soon" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Games worth gathering for" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "We're putting the finishing touches to the shop. Leave your email and we'll tell you the moment the doors open." },
    { "type": "text", "id": "form_label", "label": "Form label", "default": "Get launch-day access" },
    { "type": "text", "id": "footer_note", "label": "Footer note" }
  ]
}
{% endschema %}
