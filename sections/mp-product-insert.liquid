{%- comment -%}
  MPGames product page — BOARD GAME INSERT variant.
  A dedicated PDP for 3D-printed storage inserts sold as STL files and/or printed.
  Shares the site's visual language with mp-product.liquid but drops the board-game
  furniture (designer/artist, how-to-play, BGG, complexity) and focuses on:
  compatibility (which games), STL-vs-printed "what you get", print specs, delivery.
  Every data-driven element hides gracefully when its metafield is empty.
{%- endcomment -%}

{%- liquid
  assign m = product.metafields.custom
  assign variant = product.selected_or_first_available_variant
  assign faqs = m.faqs.value
  assign insert_games = m.insert_for_game.value

  assign on_sale = false
  if product.compare_at_price > product.price
    assign on_sale = true
    assign disc = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round
  endif

  # Real Judge.me review data only — never fabricated.
  assign rscore = blank
  assign rcount = blank
  assign jm = product.metafields.judgeme.review_widget_data.value
  if jm != blank and jm.number_of_reviews > 0
    assign rscore = jm.average_rating
    assign rcount = jm.number_of_reviews
  endif

  # Does any variant ship? (drives the "Format" framing + digital delivery notice.)
  assign has_digital = false
  assign has_physical = false
  for v in product.variants
    unless v.requires_shipping
      assign has_digital = true
    else
      assign has_physical = true
    endunless
  endfor

  # Is there anything to show in the print-specs panel?
  assign has_specs = false
  if m.insert_material.value != blank or m.insert_pieces.value != blank or m.insert_filament.value != blank or m.insert_print_time.value != blank or m.insert_build_volume.value != blank or m.insert_assembly.value != blank
    assign has_specs = true
  endif

  assign inserts_url = '/collections/board-game-inserts'
-%}

{%- style -%}
  .mp-pdpi-{{ section.id }} { background: #f4efe6; font-family: 'Barlow', ui-sans-serif, system-ui, sans-serif; color: #16323f; }
  .mp-pdpi-{{ section.id }} .pdp__wrap { max-width: 1200px; margin: 0 auto; padding: 0 28px; }
  .mp-pdpi-{{ section.id }} .pdp__crumb { padding: 16px 0 0; font-size: 12px; color: #9b948a; }
  .mp-pdpi-{{ section.id }} .pdp__crumb a { color: inherit; text-decoration: none; }
  .mp-pdpi-{{ section.id }} .pdp__crumb .sep { color: #cfc9be; margin: 0 5px; }

  .mp-pdpi-{{ section.id }} .pdp__top { display: flex; gap: 40px; padding: 18px 0 30px; }
  .mp-pdpi-{{ section.id }} .pdp__gallery { width: 540px; flex: none; }
  .mp-pdpi-{{ section.id }} .pdp__main { position: relative; border-radius: 8px; overflow: hidden; aspect-ratio: 1/1; display: flex; align-items: center; justify-content: center; }
  .mp-pdpi-{{ section.id }} .pdp__main img { width: 100%; height: 100%; object-fit: contain; display: block; }
  .mp-pdpi-{{ section.id }} .pdp__flag { position: absolute; top: 14px; left: 14px; z-index: 2; background: #d6402e; color: #fff; font-size: 13px; font-weight: 700; padding: 4px 11px; border-radius: 6px; }
  .mp-pdpi-{{ section.id }} .pdp__ph { font: 13px ui-monospace, monospace; color: #a39c92; }
  .mp-pdpi-{{ section.id }} .pdp__thumbs { display: flex; gap: 11px; margin-top: 12px; flex-wrap: wrap; }
  .mp-pdpi-{{ section.id }} .pdp__thumb { width: 86px; height: 86px; border-radius: 7px; overflow: hidden; border: 2px solid transparent; cursor: pointer; background: #e6e0d4; padding: 0; }
  .mp-pdpi-{{ section.id }} .pdp__thumb img { width: 100%; height: 100%; object-fit: cover; }
  .mp-pdpi-{{ section.id }} .pdp__thumb.is-active { border-color: #16323f; }

  .mp-pdpi-{{ section.id }} .pdp__buy { flex: 1; min-width: 0; }
  .mp-pdpi-{{ section.id }} .pdp__eyebrow { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; font-weight: 700; color: #16755a; letter-spacing: 1px; text-transform: uppercase; }
  .mp-pdpi-{{ section.id }} .pdp__vendor { font-size: 12.5px; font-weight: 600; color: #8a8278; letter-spacing: 1px; text-transform: uppercase; margin-top: 8px; }
  .mp-pdpi-{{ section.id }} .pdp__title { font-size: 44px; font-weight: 700; line-height: 1.04; margin: 6px 0 0; }
  .mp-pdpi-{{ section.id }} .pdp__meta { display: flex; align-items: center; gap: 14px; margin-top: 13px; flex-wrap: wrap; font-size: 13px; color: #6b7a82; }
  .mp-pdpi-{{ section.id }} .pdp__stars { color: #f2872f; letter-spacing: 1px; }

  .mp-pdpi-{{ section.id }} .pdp__compat { background: #eef5f2; border: 1px solid #b9d8cb; border-radius: 10px; padding: 13px 16px; margin: 18px 0 4px; display: flex; align-items: flex-start; gap: 10px; font-size: 13.5px; color: #1f5a44; line-height: 1.5; }
  .mp-pdpi-{{ section.id }} .pdp__compat a { color: #16755a; font-weight: 700; }

  .mp-pdpi-{{ section.id }} .pdp__price { display: flex; align-items: baseline; gap: 13px; margin-top: 20px; }
  .mp-pdpi-{{ section.id }} .pdp__rrp { font-size: 18px; color: #9b948a; text-decoration: line-through; }
  .mp-pdpi-{{ section.id }} .pdp__now { font-size: 34px; font-weight: 700; }
  .mp-pdpi-{{ section.id }} .pdp__saletag { background: #f5d8a8; color: #9a6b16; font-size: 13px; font-weight: 700; padding: 5px 12px; border-radius: 20px; }
  .mp-pdpi-{{ section.id }} .pdp__tax { font-size: 12.5px; color: #8a8278; margin-top: 4px; }

  .mp-pdpi-{{ section.id }} .pdp__stock { display: flex; align-items: center; gap: 8px; margin-top: 16px; font-size: 13.5px; }
  .mp-pdpi-{{ section.id }} .pdp__dot { width: 9px; height: 9px; border-radius: 50%; display: inline-block; }

  .mp-pdpi-{{ section.id }} .pdp__optgroup { margin-top: 18px; }
  .mp-pdpi-{{ section.id }} .pdp__optvals { display: flex; flex-wrap: wrap; gap: 8px; }
  .mp-pdpi-{{ section.id }} .pdp__opt { background: #fff; border: 1px solid #cdc6ba; border-radius: 8px; padding: 9px 15px; font-size: 13.5px; font-weight: 600; color: #16323f; cursor: pointer; font-family: inherit; }
  .mp-pdpi-{{ section.id }} .pdp__opt:hover { border-color: #16323f; }
  .mp-pdpi-{{ section.id }} .pdp__opt.is-active { background: #16323f; border-color: #16323f; color: #fff; }
  .mp-pdpi-{{ section.id }} .pdp__qlabel { font-size: 12.5px; color: #6b7a82; margin: 22px 0 8px; }
  .mp-pdpi-{{ section.id }} .pdp__qty { display: inline-flex; align-items: center; border: 1px solid #cdc6ba; border-radius: 8px; overflow: hidden; background: #fff; }
  .mp-pdpi-{{ section.id }} .pdp__qty button { padding: 13px 18px; color: #6b7a82; font-size: 17px; background: none; border: 0; cursor: pointer; }
  .mp-pdpi-{{ section.id }} .pdp__qty input { width: 56px; text-align: center; padding: 13px 0; font-size: 16px; font-weight: 600; color: #16323f; border: 0; border-left: 1px solid #e7e0d4; border-right: 1px solid #e7e0d4; -moz-appearance: textfield; }
  .mp-pdpi-{{ section.id }} .pdp__qty input::-webkit-outer-spin-button, .mp-pdpi-{{ section.id }} .pdp__qty input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }

  .mp-pdpi-{{ section.id }} .pdp__actions { display: flex; gap: 11px; margin-top: 16px; }
  .mp-pdpi-{{ section.id }} .pdp__add { flex: 1; background: #16323f; color: #fff; border: 0; border-radius: 8px; padding: 15px; font-size: 16px; font-weight: 700; cursor: pointer; font-family: inherit; }
  .mp-pdpi-{{ section.id }} .pdp__buynow { display: block; width: 100%; margin-top: 11px; background: #f2872f; color: #fff; border: 0; border-radius: 8px; padding: 15px; font-size: 16px; font-weight: 700; cursor: pointer; font-family: inherit; }
  .mp-pdpi-{{ section.id }} .pdp__add[disabled], .mp-pdpi-{{ section.id }} .pdp__buynow[disabled] { opacity: .5; cursor: not-allowed; }
  .mp-pdpi-{{ section.id }} .pdp__appblocks { margin-top: 12px; }

  .mp-pdpi-{{ section.id }} .pdp__reassure { border: 1px solid #e2ddd1; border-radius: 10px; background: #fbf9f4; margin-top: 18px; padding: 14px 16px; display: flex; flex-direction: column; gap: 10px; font-size: 12.5px; color: #4a443c; }
  .mp-pdpi-{{ section.id }} .pdp__reassure b { color: #16323f; }
  .mp-pdpi-{{ section.id }} .pdp__digital { background: #eef5f2; border-color: #b9d8cb; }
  .mp-pdpi-{{ section.id }} .pdp__share { display: flex; gap: 18px; margin-top: 14px; font-size: 12.5px; color: #6b7a82; }

  .mp-pdpi-{{ section.id }} .pdp__cols { display: flex; gap: 30px; padding: 8px 0 30px; align-items: flex-start; }
  .mp-pdpi-{{ section.id }} .pdp__left { flex: 1; min-width: 0; }
  .mp-pdpi-{{ section.id }} .pdp__h { font-size: 24px; font-weight: 700; margin-bottom: 16px; }

  /* What you get — STL vs printed */
  .mp-pdpi-{{ section.id }} .pdp__yg { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .mp-pdpi-{{ section.id }} .pdp__ygcard { border: 1px solid #e7ddcb; border-radius: 14px; background: #fff; padding: 20px; box-shadow: 0 1px 2px rgba(20,40,50,.04); position: relative; overflow: hidden; }
  .mp-pdpi-{{ section.id }} .pdp__ygcard .accent { position: absolute; left: 0; top: 0; bottom: 0; width: 4px; }
  .mp-pdpi-{{ section.id }} .pdp__ygico { width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 20px; }
  .mp-pdpi-{{ section.id }} .pdp__ygttl { font-size: 17px; font-weight: 700; margin: 12px 0 2px; }
  .mp-pdpi-{{ section.id }} .pdp__ygsub { font-size: 12.5px; color: #8a8278; }
  .mp-pdpi-{{ section.id }} .pdp__yglist { list-style: none; padding: 0; margin: 13px 0 0; display: flex; flex-direction: column; gap: 9px; }
  .mp-pdpi-{{ section.id }} .pdp__yglist li { display: flex; gap: 9px; align-items: flex-start; font-size: 13.5px; color: #4a443c; line-height: 1.45; }
  .mp-pdpi-{{ section.id }} .pdp__yglist .ok { color: #2f8f5b; margin-top: 1px; }

  /* Description */
  .mp-pdpi-{{ section.id }} .pdp__rte { font-size: 14.5px; line-height: 1.72; color: #3c3a34; }
  .mp-pdpi-{{ section.id }} .pdp__rte p { margin: 0 0 14px; }
  .mp-pdpi-{{ section.id }} .pdp__block { margin-top: 26px; }

  /* Insert details panel */
  .mp-pdpi-{{ section.id }} .pdp__info { width: 360px; flex: none; border: 1px solid #e2ddd1; border-radius: 12px; background: #fff; overflow: hidden; }
  .mp-pdpi-{{ section.id }} .pdp__info h3 { font-size: 17px; font-weight: 700; padding: 16px 18px; border-bottom: 1px solid #efe9dd; margin: 0; }
  .mp-pdpi-{{ section.id }} .pdp__inforow { display: flex; justify-content: space-between; gap: 16px; padding: 11px 18px; border-bottom: 1px solid #f1ece2; font-size: 13px; }
  .mp-pdpi-{{ section.id }} .pdp__inforow:last-child { border-bottom: 0; }
  .mp-pdpi-{{ section.id }} .pdp__inforow .k { color: #9b948a; }
  .mp-pdpi-{{ section.id }} .pdp__inforow .v { font-weight: 600; text-align: right; }
  .mp-pdpi-{{ section.id }} .pdp__inforow .v a { color: inherit; text-decoration: none; border-bottom: 1px solid #cdc6ba; }
  .mp-pdpi-{{ section.id }} .pdp__inforow .v a:hover { color: #c2410c; border-bottom-color: #c2410c; }

  /* Designed-for grid */
  .mp-pdpi-{{ section.id }} .pdp__also { padding: 8px 0 40px; }
  .mp-pdpi-{{ section.id }} .pdp__grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; }
  .mp-pdpi-{{ section.id }} .pdp__card { border: 1px solid #e2ddd1; border-radius: 10px; overflow: hidden; background: #fff; display: flex; flex-direction: column; }
  .mp-pdpi-{{ section.id }} .pdp__card .cmedia { height: 148px; padding: 10px; display: flex; align-items: center; justify-content: center; }
  .mp-pdpi-{{ section.id }} .pdp__card .cmedia img { width: 100%; height: 100%; object-fit: contain; }
  .mp-pdpi-{{ section.id }} .pdp__card .cbody { padding: 11px 12px 13px; display: flex; flex-direction: column; flex: 1; }
  .mp-pdpi-{{ section.id }} .pdp__card .cname { font-size: 13.5px; font-weight: 600; line-height: 1.25; text-decoration: none; color: #16323f; }
  .mp-pdpi-{{ section.id }} .pdp__card .cfoot { display: flex; align-items: flex-end; justify-content: space-between; margin-top: auto; padding-top: 11px; }
  .mp-pdpi-{{ section.id }} .pdp__card .cprice { font-size: 18px; font-weight: 700; }
  .mp-pdpi-{{ section.id }} .pdp__card .cadd { background: #f2872f; color: #fff; border-radius: 7px; padding: 8px 12px; font-size: 12.5px; font-weight: 600; text-decoration: none; }

  /* FAQ */
  .mp-pdpi-{{ section.id }} .pdp__faqitem { border-top: 1px solid #e7ddcb; }
  .mp-pdpi-{{ section.id }} .pdp__faqitem:last-of-type { border-bottom: 1px solid #e7ddcb; }
  .mp-pdpi-{{ section.id }} .pdp__faqq { cursor: pointer; padding: 13px 4px; font-size: 14px; font-weight: 600; color: #16323f; list-style: none; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .mp-pdpi-{{ section.id }} .pdp__faqq::-webkit-details-marker { display: none; }
  .mp-pdpi-{{ section.id }} .pdp__faqq::after { content: '+'; font-size: 18px; color: #f2872f; font-weight: 700; line-height: 1; }
  .mp-pdpi-{{ section.id }} .pdp__faqitem[open] .pdp__faqq::after { content: '\2212'; }
  .mp-pdpi-{{ section.id }} .pdp__faqa { padding: 0 4px 14px; font-size: 13.5px; line-height: 1.6; color: #4a443c; }

  @media (max-width: 989px) {
    .mp-pdpi-{{ section.id }} .pdp__top, .mp-pdpi-{{ section.id }} .pdp__cols { flex-direction: column; }
    .mp-pdpi-{{ section.id }} .pdp__gallery, .mp-pdpi-{{ section.id }} .pdp__info { width: 100%; }
    .mp-pdpi-{{ section.id }} .pdp__grid { grid-template-columns: repeat(2,1fr); }
  }
  @media (max-width: 749px) {
    .mp-pdpi-{{ section.id }} .pdp__wrap { padding: 0 16px; }
    .mp-pdpi-{{ section.id }} .pdp__title { font-size: 32px; }
    .mp-pdpi-{{ section.id }} .pdp__yg { grid-template-columns: 1fr; }
  }
{%- endstyle -%}

<div class="mp-pdpi-{{ section.id }}" data-pdp>
  <div class="pdp__wrap">

    <!-- breadcrumb -->
    <div class="pdp__crumb">
      <a href="{{ routes.root_url }}">Home</a>
      <span class="sep">/</span><a href="{% if collection %}{{ collection.url }}{% else %}{{ inserts_url }}{% endif %}">{% if collection %}{{ collection.title }}{% else %}Board Game Inserts{% endif %}</a>
      <span class="sep">/</span><span style="color:#6b7a82">{{ product.title }}</span>
    </div>

    <!-- gallery + buy box -->
    <div class="pdp__top">
      <div class="pdp__gallery">
        <div class="pdp__main">
          {%- if on_sale -%}<span class="pdp__flag">SALE · -{{ disc }}%</span>{%- endif -%}
          {%- if product.featured_media -%}
            <img id="pdp-main-{{ section.id }}" src="{{ product.featured_media | image_url: width: 1100 }}" alt="{{ product.featured_media.alt | escape | default: product.title }}" width="1100" height="1100">
          {%- else -%}
            <span class="pdp__ph">{{ product.title }}</span>
          {%- endif -%}
        </div>
        {%- if product.media.size > 1 -%}
          <div class="pdp__thumbs">
            {%- for media in product.media limit: 8 -%}
              <button type="button" class="pdp__thumb{% if forloop.first %} is-active{% endif %}" data-src="{{ media | image_url: width: 1100 }}" aria-label="View image {{ forloop.index }}">
                <img src="{{ media | image_url: width: 180 }}" alt="{{ media.alt | default: product.title | escape }}" width="180" height="180" loading="lazy">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <div class="pdp__buy">
        <span class="pdp__eyebrow">&#128230; 3D-Printed Board Game Insert</span>
        {%- if product.vendor != blank -%}<div class="pdp__vendor">{{ product.vendor }}</div>{%- endif -%}
        <h1 class="pdp__title">{{ product.title }}</h1>

        <div class="pdp__meta">
          <span class="pdp__sub"><div class="jdgm-widget jdgm-preview-badge" data-id="{{ product.id }}">{{ product.metafields.judgeme.badge }}</div></span>
        </div>

        {%- comment -%} Compatibility — the #1 thing an insert buyer needs to know {%- endcomment -%}
        {%- if insert_games != blank and insert_games.size > 0 -%}
          <div class="pdp__compat">&#127919; <span><strong>Designed to fit</strong> {% for g in insert_games %}{%- unless forloop.first -%}{%- if forloop.last -%} &amp; {%- else -%}, {%- endif -%}{%- endunless -%}<a href="{{ g.url }}">{{ g.title }}</a>{% endfor %}. Check your edition &mdash; box sizes occasionally change between printings.</span></div>
        {%- endif -%}

        <div class="pdp__price">
          <span class="pdp__rrp" data-rrp{% unless on_sale %} hidden{% endunless %}>{{ product.compare_at_price | money }}</span>
          <span class="pdp__now" data-price>{{ product.price | money }}</span>
          <span class="pdp__saletag" data-saletag{% unless on_sale %} hidden{% endunless %}>Save {{ disc }}%</span>
        </div>
        <div class="pdp__tax">Taxes included<span data-ships-note{% if variant.requires_shipping == false %} hidden{% endif %}> · {{ section.settings.delivery_line }}</span></div>

        {%- unless product.has_only_default_variant -%}
          <div data-options>
            {%- for option in product.options_with_values -%}
              <div class="pdp__optgroup" data-option-index="{{ forloop.index0 }}">
                <div class="pdp__qlabel" style="margin:0 0 8px">{{ option.name }}</div>
                <div class="pdp__optvals">
                  {%- for value in option.values -%}
                    <button type="button" class="pdp__opt{% if option.selected_value == value %} is-active{% endif %}" data-option-value data-value="{{ value | escape }}">{{ value }}</button>
                  {%- endfor -%}
                </div>
              </div>
            {%- endfor -%}
          </div>
        {%- endunless -%}

        <div class="pdp__stock" data-stock>
          {%- if product.available -%}
            <span class="pdp__dot" style="background:#2f8f5b"></span><b style="color:#2f8f5b">{% if variant.requires_shipping == false %}Available to download{% else %}In stock &amp; ready to print{% endif %}</b>
            {%- if variant.inventory_management and variant.inventory_quantity > 0 -%}<span style="color:#6b7a82"> · {{ variant.inventory_quantity }} available</span>{%- endif -%}
          {%- else -%}
            <span class="pdp__dot" style="background:#d6402e"></span><b style="color:#d6402e">Currently unavailable</b>
          {%- endif -%}
        </div>

        <div class="pdp__qlabel">Quantity</div>
        <div class="pdp__qty">
          <button type="button" data-q="-1" aria-label="Decrease quantity">&minus;</button>
          <input type="number" id="pdp-qty-{{ section.id }}" value="1" min="1" inputmode="numeric">
          <button type="button" data-q="1" aria-label="Increase quantity">+</button>
        </div>

        <div class="pdp__actions">
          <button type="button" class="pdp__add" data-add="cart"{% unless product.available %} disabled{% endunless %}>Add to basket</button>
        </div>
        <button type="button" class="pdp__buynow" data-add="checkout"{% unless product.available %} disabled{% endunless %}>Buy it now</button>

        {%- if section.blocks.size > 0 -%}
          <div class="pdp__appblocks">
            {%- for block in section.blocks -%}
              {%- if block.type == '@app' -%}{% render block %}{%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- comment -%} Physical reassurance vs digital-download notice, toggled by the selected variant's requires_shipping {%- endcomment -%}
        {%- if has_physical -%}
          <div class="pdp__reassure" data-physical-notice{% if variant.requires_shipping == false %} hidden{% endif %}>
            <span>&#128666; <b>Printed &amp; shipped from the UK</b> · dispatched within {{ section.settings.print_dispatch | default: '3–5 working days' }} (printed to order)</span>
            <span>&#128295; <b>Ready to use</b> · cleaned, test-fitted and packed flat</span>
            <span>&#8634; <b>30-day returns</b> on unused printed inserts in original condition</span>
          </div>
        {%- endif -%}
        {%- if has_digital -%}
          <div class="pdp__reassure pdp__digital" data-digital-notice{% unless variant.requires_shipping == false %} hidden{% endunless %}>
            <span>&#11015; <b>Instant digital download</b> · your STL files are emailed the moment your order is confirmed — nothing ships</span>
            <span>&#128424; <b>Print it yourself</b> · ready-to-slice STL files for any FDM 3D printer{% if m.insert_build_volume.value != blank %} · needs a {{ m.insert_build_volume.value }} bed{% endif %}</span>
            <span>&#128274; <b>Personal-use licence</b> · print for your own copies; please don&rsquo;t resell the prints or files</span>
          </div>
        {%- endif -%}

        <div class="pdp__share">
          <span data-sku{% if variant.sku == blank %} hidden{% endif %}>SKU: {{ variant.sku }}</span>
        </div>
      </div>
    </div>

    <!-- what you get + insert details -->
    <div class="pdp__cols">
      <div class="pdp__left">
        {%- if has_digital or has_physical -%}
          <div class="pdp__h">Choose how you buy it</div>
          <div class="pdp__yg">
            {%- if has_digital -%}
              <div class="pdp__ygcard"><span class="accent" style="background:#16755a"></span>
                <span class="pdp__ygico" style="background:#e3f1e9">&#11015;</span>
                <div class="pdp__ygttl">STL Digital Download</div>
                <div class="pdp__ygsub">Print it yourself</div>
                <ul class="pdp__yglist">
                  <li><span class="ok">&#10003;</span> Ready-to-slice STL files, delivered instantly by email</li>
                  <li><span class="ok">&#10003;</span> Print in any colour/material you like, as many times as you need for your own copies</li>
                  <li><span class="ok">&#10003;</span> Supports-free where possible for easy home printing</li>
                  <li><span class="ok">&#10003;</span> Best value — no shipping, no wait</li>
                </ul>
              </div>
            {%- endif -%}
            {%- if has_physical -%}
              <div class="pdp__ygcard"><span class="accent" style="background:#f2872f"></span>
                <span class="pdp__ygico" style="background:#fbeadb">&#128230;</span>
                <div class="pdp__ygttl">3D Printed</div>
                <div class="pdp__ygsub">We print &amp; ship it</div>
                <ul class="pdp__yglist">
                  <li><span class="ok">&#10003;</span> Professionally printed to order and shipped to your door</li>
                  <li><span class="ok">&#10003;</span> Test-fitted to the game box before it leaves us</li>
                  <li><span class="ok">&#10003;</span> No printer needed — arrives ready to drop in</li>
                  <li><span class="ok">&#10003;</span> Sturdy PLA{% if m.insert_material.value != blank %}/{{ m.insert_material.value }}{% endif %}, packed flat and protected</li>
                </ul>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if product.description != blank -%}
          <div class="pdp__block">
            <div class="pdp__h" style="font-size:19px">About this insert</div>
            <div class="pdp__rte">{{ product.description }}</div>
          </div>
        {%- endif -%}

        {%- if faqs != blank and faqs.size > 0 -%}
          <div class="pdp__block">
            <div class="pdp__h" style="font-size:19px">Frequently asked questions</div>
            {%- for f in faqs -%}
              <details class="pdp__faqitem">
                <summary class="pdp__faqq">{{ f.q }}</summary>
                <div class="pdp__faqa">{{ f.a }}</div>
              </details>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- if has_specs or insert_games != blank -%}
        <div class="pdp__info">
          <h3>Insert details</h3>
          {%- if m.insert_pieces.value != blank -%}<div class="pdp__inforow"><span class="k">Includes</span><span class="v">{{ m.insert_pieces.value }}</span></div>{%- endif -%}
          {%- if m.insert_material.value != blank -%}<div class="pdp__inforow"><span class="k">Material</span><span class="v">{{ m.insert_material.value }}</span></div>{%- endif -%}
          {%- if m.insert_assembly.value != blank -%}<div class="pdp__inforow"><span class="k">Assembly</span><span class="v">{{ m.insert_assembly.value }}</span></div>{%- endif -%}
          {%- if has_digital -%}<div class="pdp__inforow"><span class="k">File format</span><span class="v">STL</span></div>{%- endif -%}
          {%- if m.insert_build_volume.value != blank -%}<div class="pdp__inforow"><span class="k">Min. build volume</span><span class="v">{{ m.insert_build_volume.value }}</span></div>{%- endif -%}
          {%- if m.insert_filament.value != blank -%}<div class="pdp__inforow"><span class="k">Filament use</span><span class="v">{{ m.insert_filament.value }}</span></div>{%- endif -%}
          {%- if m.insert_print_time.value != blank -%}<div class="pdp__inforow"><span class="k">Print time</span><span class="v">{{ m.insert_print_time.value }}</span></div>{%- endif -%}
          {%- if insert_games != blank and insert_games.size > 0 -%}
            <div class="pdp__inforow"><span class="k">Fits</span><span class="v">{% for g in insert_games %}{%- unless forloop.first -%}, {% endunless -%}<a href="{{ g.url }}">{{ g.title }}</a>{% endfor %}</span></div>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    <!-- reviews (Judge.me) -->
    <div class="pdp__reviews" id="reviews">
      <div class="jdgm-widget jdgm-review-widget" data-id="{{ product.id }}">{{ product.metafields.judgeme.widget }}</div>
    </div>

    <!-- the games this insert is for -->
    {%- if insert_games != blank and insert_games.size > 0 -%}
      <div class="pdp__also">
        <div class="pdp__h">Games this insert is made for</div>
        <div class="pdp__grid">
          {%- for g in insert_games limit: 4 -%}
            <div class="pdp__card">
              <a href="{{ g.url }}" class="cmedia">{% if g.featured_image %}<img src="{{ g.featured_image | image_url: width: 360 }}" alt="{{ g.title | escape }}" width="360" height="360" loading="lazy">{% endif %}</a>
              <div class="cbody">
                <a class="cname" href="{{ g.url }}">{{ g.title }}</a>
                {%- if g.vendor != blank -%}<div style="font-size:11.5px;color:#9b948a;margin-top:2px">{{ g.vendor }}</div>{%- endif -%}
                <div class="cfoot">
                  <div class="cprice">{{ g.price | money }}</div>
                  <a class="cadd" href="{{ g.url }}">View</a>
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

  </div>
</div>

{%- comment -%} Structured data (Product + Breadcrumb + FAQ). No board-game/BGG fields. {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Product",
      "name": {{ product.title | json }},
      "url": {{ canonical_url | json }},
      {%- assign schema_img = product.featured_image | default: product.media.first.preview_image -%}
      {% if schema_img %}"image": {{ schema_img | image_url: width: 1200 | prepend: "https:" | json }},{% endif %}
      "description": {{ product.description | default: product.title | strip_html | truncatewords: 60 | truncate: 500 | json }},
      {% if product.vendor != blank %}"brand": { "@type": "Brand", "name": {{ product.vendor | json }} },{% endif %}
      {% if variant.sku != blank %}"sku": {{ variant.sku | json }},{% endif %}
      {% if variant.sku != blank %}"mpn": {{ variant.sku | json }},{% endif %}
      {% if product.type != blank %}"category": {{ product.type | json }},{% endif %}
      {% if rcount != blank and rscore != blank %}"aggregateRating": { "@type": "AggregateRating", "ratingValue": "{{ rscore }}", "reviewCount": "{{ rcount }}", "bestRating": "5", "worstRating": "1" },{% endif %}
      {% if product.variants.size > 1 %}
      "offers": {
        "@type": "AggregateOffer",
        "priceCurrency": {{ cart.currency.iso_code | json }},
        "lowPrice": {{ product.price_min | divided_by: 100.0 }},
        "highPrice": {{ product.price_max | divided_by: 100.0 }},
        "offerCount": {{ product.variants.size }},
        "availability": "https://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}",
        "url": {{ canonical_url | json }}
      }
      {% else %}
      "offers": {
        "@type": "Offer",
        "priceCurrency": {{ cart.currency.iso_code | json }},
        "price": {{ variant.price | divided_by: 100.0 }},
        "availability": "https://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}",
        "itemCondition": "https://schema.org/NewCondition",
        "url": {{ canonical_url | json }}
      }
      {% endif %}
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": {{ shop.url | append: routes.root_url | json }} },
        { "@type": "ListItem", "position": 2, "name": "Board Game Inserts", "item": {{ shop.url | append: inserts_url | json }} },
        { "@type": "ListItem", "position": 3, "name": {{ product.title | json }}, "item": {{ canonical_url | json }} }
      ]
    }{% if faqs and faqs.size > 0 %},
    {
      "@type": "FAQPage",
      "mainEntity": [
        {%- for f in faqs -%}{ "@type": "Question", "name": {{ f.q | json }}, "acceptedAnswer": { "@type": "Answer", "text": {{ f.a | strip_html | json }} } }{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}
      ]
    }{% endif %}
  ]
}
</script>

<script>
  (function () {
    var root = document.currentScript.previousElementSibling;
    while (root && !root.hasAttribute('data-pdp')) { root = root.previousElementSibling; }
    if (!root) root = document.querySelector('.mp-pdpi-{{ section.id }}');
    if (!root) return;

    // gallery thumbnails
    var main = root.querySelector('#pdp-main-{{ section.id }}');
    root.querySelectorAll('.pdp__thumb').forEach(function (t) {
      t.addEventListener('click', function () {
        if (main) main.src = t.getAttribute('data-src');
        root.querySelectorAll('.pdp__thumb').forEach(function (x) { x.classList.remove('is-active'); });
        t.classList.add('is-active');
      });
    });

    // quantity
    var qty = root.querySelector('#pdp-qty-{{ section.id }}');
    root.querySelectorAll('[data-q]').forEach(function (b) {
      b.addEventListener('click', function () {
        var v = parseInt(qty.value, 10) || 1;
        v += parseInt(b.getAttribute('data-q'), 10);
        if (v < 1) v = 1;
        qty.value = v;
      });
    });

    // variant selection
    var variants = [
      {%- for v in product.variants -%}
        { "id": {{ v.id }}, "options": {{ v.options | json }}, "available": {{ v.available }}, "price_str": {{ v.price | money | json }}, "compare_str": {% if v.compare_at_price > v.price %}{{ v.compare_at_price | money | json }}{% else %}null{% endif %}, "sku": {{ v.sku | json }}, "avail_qty": {% if v.inventory_management and v.inventory_quantity > 0 %}{{ v.inventory_quantity }}{% else %}0{% endif %}, "requires_shipping": {{ v.requires_shipping }} }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ];
    var variantId = {{ variant.id | default: 'null' }};

    var optionGroups = root.querySelectorAll('[data-options] [data-option-index]');
    var priceEl = root.querySelector('[data-price]');
    var rrpEl = root.querySelector('[data-rrp]');
    var saleEl = root.querySelector('[data-saletag]');
    var stockEl = root.querySelector('[data-stock]');
    var skuEl = root.querySelector('[data-sku]');
    var addBtn = root.querySelector('.pdp__add');
    var buyBtn = root.querySelector('.pdp__buynow');
    var physNotice = root.querySelector('[data-physical-notice]');
    var digiNotice = root.querySelector('[data-digital-notice]');
    var shipsNote = root.querySelector('[data-ships-note]');

    function currentSelections() {
      return Array.prototype.map.call(optionGroups, function (group) {
        var active = group.querySelector('.pdp__opt.is-active');
        return active ? active.getAttribute('data-value') : null;
      });
    }
    function matchVariant(sel) {
      return variants.filter(function (v) {
        return v.options.length === sel.length && v.options.every(function (o, i) { return o === sel[i]; });
      })[0];
    }
    function updateForVariant(v) {
      if (!v) {
        variantId = null;
        if (addBtn) { addBtn.disabled = true; addBtn.textContent = 'Unavailable'; }
        if (buyBtn) buyBtn.disabled = true;
        return;
      }
      variantId = v.id;
      if (priceEl) priceEl.innerHTML = v.price_str;
      if (rrpEl) { if (v.compare_str) { rrpEl.innerHTML = v.compare_str; rrpEl.hidden = false; } else { rrpEl.hidden = true; } }
      if (saleEl) saleEl.hidden = !v.compare_str;
      if (skuEl) { if (v.sku) { skuEl.textContent = 'SKU: ' + v.sku; skuEl.hidden = false; } else { skuEl.hidden = true; } }
      var digital = v.requires_shipping === false;
      if (stockEl) {
        stockEl.innerHTML = v.available
          ? '<span class="pdp__dot" style="background:#2f8f5b"></span><b style="color:#2f8f5b">' + (digital ? 'Available to download' : 'In stock &amp; ready to print') + '</b>' + (v.avail_qty > 0 ? '<span style="color:#6b7a82"> · ' + v.avail_qty + ' available</span>' : '')
          : '<span class="pdp__dot" style="background:#d6402e"></span><b style="color:#d6402e">Currently unavailable</b>';
      }
      if (addBtn) { addBtn.disabled = !v.available; addBtn.textContent = !v.available ? 'Sold out' : 'Add to basket'; }
      if (buyBtn) buyBtn.disabled = !v.available;
      if (physNotice) physNotice.hidden = digital;
      if (digiNotice) digiNotice.hidden = !digital;
      if (shipsNote) shipsNote.hidden = digital;
      try {
        var url = new URL(window.location.href);
        url.searchParams.set('variant', v.id);
        window.history.replaceState({}, '', url);
      } catch (e) {}
    }
    root.querySelectorAll('[data-option-value]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var group = btn.closest('[data-option-index]');
        if (group) {
          group.querySelectorAll('.pdp__opt').forEach(function (x) { x.classList.remove('is-active'); });
          btn.classList.add('is-active');
        }
        updateForVariant(matchVariant(currentSelections()));
      });
    });

    // add to cart / buy now
    root.querySelectorAll('[data-add]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        if (!variantId) return;
        var dest = btn.getAttribute('data-add') === 'checkout' ? '/checkout' : '{{ routes.cart_url }}';
        btn.disabled = true;
        fetch('{{ routes.cart_add_url }}', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ items: [{ id: variantId, quantity: parseInt(qty.value, 10) || 1 }] })
        }).then(function (r) { return r.json(); }).then(function () {
          window.location.href = dest;
        }).catch(function () { btn.disabled = false; });
      });
    });
  })();
</script>

