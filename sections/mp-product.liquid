  .mp-pdp-{{ section.id }} .pdp__title { font-size: 44px; font-weight: 700; line-height: 1.04; margin: 6px 0 0; }
  .mp-pdp-{{ section.id }} .pdp__meta { display: flex; align-items: center; gap: 14px; margin-top: 13px; flex-wrap: wrap; }
  .mp-pdp-{{ section.id }} .pdp__bgg { display: inline-flex; align-items: center; gap: 5px; background: #2b2233; border-radius: 6px; padding: 4px 9px; }
  .mp-pdp-{{ section.id }} .pdp__bgg b { font-size: 11px; font-weight: 700; color: #fff; letter-spacing: .5px; }
  .mp-pdp-{{ section.id }} .pdp__sub { font-size: 13px; color: #6b7a82; }
  .mp-pdp-{{ section.id }} .pdp__divider { width: 1px; height: 14px; background: #d8d0c2; }
  .mp-pdp-{{ section.id }} .pdp__stars { color: #f2872f; letter-spacing: 1px; }

