{%- comment -%}
  MPGames product page — full custom product layout imported from Claude Design
  "MPGames Product". Wired to real product data + custom.* board-game metafields.
  Every data-driven element hides gracefully when its metafield is empty.
{%- endcomment -%}

{%- liquid
  assign m = product.metafields.custom
  assign variant = product.selected_or_first_available_variant

  assign bgg = m.bgg_rating.value
  assign bggn = bgg | times: 1.0
  assign bggdisp = bggn | round: 1
  assign bgg_color = '#e0b441'
  if bggn >= 8.0
    assign bgg_color = '#5fbf7e'
  elsif bggn >= 7.0
    assign bgg_color = '#9ccf63'
  endif

  assign weight = m.weight.value
  assign show_weight = false
  if weight != blank and weight > 0
    assign show_weight = true
  endif
-%}
{%- comment -%} Designer/artist fields may hold several names (comma- or semicolon-separated); link each person to its own collection {%- endcomment -%}
{%- assign designer_names = m.designer.value | replace: ';', ',' | split: ',' -%}
{%- capture designer_links -%}{%- for n in designer_names -%}{%- assign nm = n | strip -%}{%- if forloop.first == false -%}, {% endif -%}<a href="/collections/designer-{{ nm | handle }}">{{ nm }}</a>{%- endfor -%}{%- endcapture -%}
{%- assign artist_names = m.artist.value | replace: ';', ',' | split: ',' -%}
{%- capture artist_links -%}{%- for n in artist_names -%}{%- assign nm = n | strip -%}{%- if forloop.first == false -%}, {% endif -%}<a href="/collections/artist-{{ nm | handle }}">{{ nm }}</a>{%- endfor -%}{%- endcapture -%}
{%- liquid

  assign on_sale = false
  if product.compare_at_price > product.price
    assign on_sale = true
    assign disc = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round
  endif

  # RRP from the custom.mrsp metafield (manufacturer's suggested retail price).
  # Stored as a number_decimal (e.g. 29.99); accept a money-type value too, just in
  # case. Shown as a struck-through RRP when it's above the current price and there
  # isn't already a compare-at sale price doing the same job.
  assign msrp_mf = m.mrsp.value
  if msrp_mf == blank
    assign msrp_mf = m.msrp.value
  endif
  assign msrp_cents = 0
  if msrp_mf != blank
    if msrp_mf.amount
      assign msrp_cents = msrp_mf.amount | times: 100 | round
      assign msrp_money = msrp_mf | money
    else
      assign msrp_cents = msrp_mf | times: 100 | round
      assign msrp_money = msrp_cents | money
    endif
  endif
  assign has_msrp = false
  if msrp_cents > product.price and on_sale == false
    assign has_msrp = true
    assign msrp_save_money = msrp_cents | minus: product.price | money
  endif

  assign is_preorder = m.is_preorder.value
  assign preorder_eta = m.preorder_eta.value

  assign mechanics = m.mechanics.value
  assign faqs = m.faqs.value

  # Ratings: prefer real Judge.me review data; fall back to manual metafields. Never fabricate.
  assign rscore = m.review_score.value
  assign rcount = m.review_count.value
  assign jm = product.metafields.judgeme.review_widget_data.value
  if jm != blank and jm.number_of_reviews > 0
    assign rscore = jm.average_rating
    assign rcount = jm.number_of_reviews
  endif
-%}

{%- style -%}
  .mp-pdp-{{ section.id }} { background: #f4efe6; font-family: 'Barlow', ui-sans-serif, system-ui, sans-serif; color: #16323f; overflow-x: clip; }
