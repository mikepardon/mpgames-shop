  .mp-pdp-{{ section.id }} .pdp__card .cbody { padding: 11px 12px 13px; display: flex; flex-direction: column; flex: 1; }
  .mp-pdp-{{ section.id }} .pdp__card .cname { font-size: 13.5px; font-weight: 600; line-height: 1.25; text-decoration: none; color: #16323f; }
  .mp-pdp-{{ section.id }} .pdp__card .cfoot { display: flex; align-items: flex-end; justify-content: space-between; margin-top: auto; padding-top: 11px; }
  .mp-pdp-{{ section.id }} .pdp__card .cprice { font-size: 18px; font-weight: 700; }
  .mp-pdp-{{ section.id }} .pdp__card .cadd { background: #f2872f; color: #fff; border-radius: 7px; padding: 8px 12px; font-size: 12.5px; font-weight: 600; text-decoration: none; }
  .mp-pdp-{{ section.id }} .pdp__viewall { font-size: 12.5px; color: #f2872f; font-weight: 600; text-decoration: none; }
  .mp-pdp-{{ section.id }} .pdp__exp-banner { background: #fff3e8; border: 1px solid #f2c79a; border-radius: 10px; padding: 13px 16px; margin: 0 0 4px; display: flex; align-items: center; gap: 10px; font-size: 13.5px; color: #7a4a16; }
  .mp-pdp-{{ section.id }} .pdp__exp-banner a { color: #c2410c; font-weight: 700; }
  .mp-pdp-{{ section.id }} .pdp__insert-banner { background: #eef5f2; border: 1px solid #b9d8cb; border-radius: 10px; padding: 13px 16px; margin: 0 0 4px; display: flex; align-items: center; gap: 10px; font-size: 13.5px; color: #1f5a44; }
  .mp-pdp-{{ section.id }} .pdp__insert-banner a { color: #16755a; font-weight: 700; }
  .mp-pdp-{{ section.id }} .pdp__digital { background: #eef5f2; border-color: #b9d8cb; }

  /* buy-box add-on (storage insert) quick-add card */
  .mp-pdp-{{ section.id }} .pdp__addon { margin-top: 14px; border: 1px solid #b9d8cb; background: #eef5f2; border-radius: 10px; padding: 12px 14px; }
  .mp-pdp-{{ section.id }} .pdp__addon-h { font-size: 12px; font-weight: 700; color: #1f5a44; text-transform: uppercase; letter-spacing: .6px; display: flex; align-items: center; gap: 6px; margin-bottom: 10px; }
  .mp-pdp-{{ section.id }} .pdp__addon-row { display: flex; align-items: center; gap: 12px; }
  .mp-pdp-{{ section.id }} .pdp__addon-row + .pdp__addon-row { margin-top: 10px; padding-top: 10px; border-top: 1px solid #cfe3da; }
  .mp-pdp-{{ section.id }} .pdp__addon-thumb { width: 52px; height: 52px; border-radius: 8px; background: #fff; flex: none; display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .mp-pdp-{{ section.id }} .pdp__addon-thumb img { width: 100%; height: 100%; object-fit: contain; }
  .mp-pdp-{{ section.id }} .pdp__addon-info { flex: 1; min-width: 0; }
  .mp-pdp-{{ section.id }} .pdp__addon-name { font-size: 13px; font-weight: 600; color: #16323f; text-decoration: none; display: block; line-height: 1.2; }
  .mp-pdp-{{ section.id }} .pdp__addon-name:hover { color: #16755a; }
  .mp-pdp-{{ section.id }} .pdp__addon-price { font-size: 12.5px; color: #1f5a44; font-weight: 700; margin-top: 3px; }
  .mp-pdp-{{ section.id }} .pdp__addon-btn { flex: none; background: #16755a; color: #fff; border: 0; border-radius: 7px; padding: 9px 15px; font-size: 12.5px; font-weight: 700; cursor: pointer; font-family: inherit; }
  .mp-pdp-{{ section.id }} .pdp__addon-btn:hover { background: #125f49; }
  .mp-pdp-{{ section.id }} .pdp__addon-btn.is-added { background: #2f8f5b; }
  .mp-pdp-{{ section.id }} .pdp__addon-btn[disabled] { opacity: .65; cursor: default; }

  /* post-add cross-sell modal */
  .mp-pdp-{{ section.id }} .pdp__modal { position: fixed; inset: 0; z-index: 9999; display: flex; align-items: center; justify-content: center; padding: 20px; }
  .mp-pdp-{{ section.id }} .pdp__modal[hidden] { display: none; }
  .mp-pdp-{{ section.id }} .pdp__modal-ov { position: absolute; inset: 0; background: rgba(16,32,40,.55); }
  .mp-pdp-{{ section.id }} .pdp__modal-panel { position: relative; z-index: 1; background: #f4efe6; border-radius: 16px; max-width: 640px; width: 100%; max-height: 88vh; overflow: auto; box-shadow: 0 20px 60px rgba(0,0,0,.32); padding: 26px; }
  .mp-pdp-{{ section.id }} .pdp__modal-close { position: absolute; top: 12px; right: 16px; background: none; border: 0; font-size: 26px; line-height: 1; color: #8a8278; cursor: pointer; }
  .mp-pdp-{{ section.id }} .pdp__modal-badge { display: inline-flex; align-items: center; gap: 7px; background: #e3f1e9; color: #2f8f5b; font-size: 12.5px; font-weight: 700; padding: 5px 12px; border-radius: 20px; }
  .mp-pdp-{{ section.id }} .pdp__modal-h { font-size: 25px; font-weight: 700; color: #16323f; margin: 13px 0 4px; }
  .mp-pdp-{{ section.id }} .pdp__modal-sub { font-size: 13.5px; color: #6b7a82; margin-bottom: 18px; line-height: 1.5; }
  .mp-pdp-{{ section.id }} .pdp__modal-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .mp-pdp-{{ section.id }} .pdp__modal-card { border: 1px solid #e2ddd1; background: #fff; border-radius: 12px; padding: 12px; display: flex; flex-direction: column; }
  .mp-pdp-{{ section.id }} .pdp__modal-card .mc-media { height: 120px; display: flex; align-items: center; justify-content: center; margin-bottom: 8px; }
  .mp-pdp-{{ section.id }} .pdp__modal-card .mc-media img { max-width: 100%; max-height: 100%; object-fit: contain; }
  .mp-pdp-{{ section.id }} .pdp__modal-tag { align-self: flex-start; font-size: 10px; font-weight: 700; letter-spacing: .5px; text-transform: uppercase; padding: 2px 7px; border-radius: 5px; margin-bottom: 8px; }
  .mp-pdp-{{ section.id }} .pdp__modal-tag--exp { background: #fff3e8; color: #c2410c; }
  .mp-pdp-{{ section.id }} .pdp__modal-tag--ins { background: #eef5f2; color: #16755a; }
  .mp-pdp-{{ section.id }} .pdp__modal-name { font-size: 13.5px; font-weight: 600; color: #16323f; text-decoration: none; line-height: 1.25; }
  .mp-pdp-{{ section.id }} .pdp__modal-name:hover { color: #c2410c; }
  .mp-pdp-{{ section.id }} .pdp__modal-foot { display: flex; align-items: center; justify-content: space-between; margin-top: 10px; padding-top: 10px; }
  .mp-pdp-{{ section.id }} .pdp__modal-price { font-size: 16px; font-weight: 700; color: #16323f; }
  .mp-pdp-{{ section.id }} .pdp__modal-add { background: #f2872f; color: #fff; border: 0; border-radius: 7px; padding: 8px 15px; font-size: 12.5px; font-weight: 700; cursor: pointer; font-family: inherit; }
  .mp-pdp-{{ section.id }} .pdp__modal-add:hover { background: #e0761f; }
  .mp-pdp-{{ section.id }} .pdp__modal-add.is-added { background: #2f8f5b; }
  .mp-pdp-{{ section.id }} .pdp__modal-add[disabled] { opacity: .65; cursor: default; }
  .mp-pdp-{{ section.id }} .pdp__modal-actions { display: flex; align-items: center; gap: 16px; margin-top: 22px; }
  .mp-pdp-{{ section.id }} .pdp__modal-actions .go { flex: 1; background: #16323f; color: #fff; text-align: center; text-decoration: none; border-radius: 9px; padding: 13px; font-size: 14px; font-weight: 700; }
  .mp-pdp-{{ section.id }} .pdp__modal-actions .dismiss { background: none; border: 0; color: #6b7a82; font-size: 13px; font-weight: 600; cursor: pointer; font-family: inherit; text-decoration: underline; white-space: nowrap; }
  @media (max-width: 600px) { .mp-pdp-{{ section.id }} .pdp__modal-grid { grid-template-columns: 1fr; } }

  @media (max-width: 989px) {
    .mp-pdp-{{ section.id }} .pdp__top, .mp-pdp-{{ section.id }} .pdp__cols { flex-direction: column; }
    .mp-pdp-{{ section.id }} .pdp__gallery, .mp-pdp-{{ section.id }} .pdp__play, .mp-pdp-{{ section.id }} .pdp__info { width: 100%; }
    .mp-pdp-{{ section.id }} .pdp__grid { grid-template-columns: repeat(2,1fr); }
  }
  @media (max-width: 749px) {
    .mp-pdp-{{ section.id }} .pdp__wrap { padding: 0 16px; }
    .mp-pdp-{{ section.id }} .pdp__title { font-size: 32px; }
    /* Game at a glance: keep the spec cards two-up on mobile (rating cells wrap 2-up on their own) */
    .mp-pdp-{{ section.id }} .pdp__specs { grid-template-columns: 1fr 1fr; }
    .mp-pdp-{{ section.id }} .pdp__h { font-size: 21px; }
  }
{%- endstyle -%}

<div class="mp-pdp-{{ section.id }}" data-pdp>
  <div class="pdp__wrap">

    <!-- breadcrumb -->
    <div class="pdp__crumb">
      <a href="{{ routes.root_url }}">Home</a>
      {%- if collection -%}<span class="sep">/</span><a href="{{ collection.url }}">{{ collection.title }}</a>{%- endif -%}
      <span class="sep">/</span><span style="color:#6b7a82">{{ product.title }}</span>
    </div>

    <!-- gallery + buy box -->
    <div class="pdp__top">
      <div class="pdp__gallery">
        <div class="pdp__main">
          {%- if on_sale -%}<span class="pdp__flag">SALE · -{{ disc }}%</span>{%- endif -%}
          {%- if product.featured_media -%}
            <img id="pdp-main-{{ section.id }}" src="{{ product.featured_media | image_url: width: 1100 }}" alt="{{ product.featured_media.alt | escape | default: product.title }}" width="1100" height="1100">
          {%- else -%}
            <span style="font:13px ui-monospace,monospace;color:#a39c92">{{ product.title }}</span>
          {%- endif -%}
        </div>
        {%- if product.media.size > 1 -%}
          <div class="pdp__thumbs">
            {%- for media in product.media limit: 8 -%}
              <button type="button" class="pdp__thumb{% if forloop.first %} is-active{% endif %}" data-src="{{ media | image_url: width: 1100 }}" aria-label="View image {{ forloop.index }}">
                <img src="{{ media | image_url: width: 180 }}" alt="{{ media.alt | default: product.title | escape }}" width="180" height="180" loading="lazy">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <div class="pdp__buy">
        {%- if product.vendor != blank -%}<div class="pdp__vendor"><a href="/collections/publisher-{{ product.vendor | handle }}">{{ product.vendor }}</a></div>{%- endif -%}
        <h1 class="pdp__title">{{ product.title }}</h1>

        <div class="pdp__meta">
          {%- if bgg != blank -%}
            <span class="pdp__bgg"><b>BGG</b><span style="font-size:13px;font-weight:700;color:{{ bgg_color }}">{{ bggdisp }}</span></span>
            {%- if m.bgg_rank.value != blank -%}<span class="pdp__sub">rank #{{ m.bgg_rank.value }}</span>{%- endif -%}
            <span class="pdp__divider"></span>
          {%- endif -%}
          <span class="pdp__sub"><div class="jdgm-widget jdgm-preview-badge" data-id="{{ product.id }}">{{ product.metafields.judgeme.badge }}</div></span>
        </div>

        <div class="pdp__price">
          <span class="pdp__rrp" data-rrp{% unless on_sale %} hidden{% endunless %}>{{ product.compare_at_price | money }}</span>
          {%- if has_msrp -%}<span class="pdp__rrp pdp__msrp" data-msrp-rrp><span class="pdp__rrp-label">RRP</span> <span class="pdp__rrp-val">{{ msrp_money }}</span></span>{%- endif -%}
          <span class="pdp__now" data-price>{{ product.price | money }}</span>
          <span class="pdp__saletag" data-saletag{% unless on_sale %} hidden{% endunless %}>Sale</span>
          {%- if has_msrp -%}<span class="pdp__saletag pdp__savetag" data-msrp-save>Save {{ msrp_save_money }}</span>{%- endif -%}
        </div>
        <div class="pdp__tax">Taxes included<span data-ships-note{% if variant.requires_shipping == false %} hidden{% endif %}> · {{ section.settings.delivery_line }}</span></div>

        {%- unless product.has_only_default_variant -%}
          <div class="pdp__options" data-options>
            {%- for option in product.options_with_values -%}
              <div class="pdp__optgroup" data-option-index="{{ forloop.index0 }}">
                <div class="pdp__qlabel" style="margin:0 0 8px">{{ option.name }}</div>
                <div class="pdp__optvals">
                  {%- for value in option.values -%}
                    <button type="button" class="pdp__opt{% if option.selected_value == value %} is-active{% endif %}" data-option-value data-value="{{ value | escape }}">{{ value }}</button>
                  {%- endfor -%}
                </div>
              </div>
            {%- endfor -%}
          </div>
        {%- endunless -%}

        <div class="pdp__stock" data-stock>
          {%- if is_preorder -%}
            <span class="pdp__dot" style="background:#f2872f"></span><b style="color:#b4560f">Available to pre-order</b>
          {%- elsif product.available -%}
            <span class="pdp__dot" style="background:#2f8f5b"></span><b style="color:#2f8f5b">In stock</b>
            {%- if variant.inventory_management and variant.inventory_quantity > 0 -%}<span style="color:#6b7a82"> · {{ variant.inventory_quantity }} available</span>{%- endif -%}
          {%- else -%}
            <span class="pdp__dot" style="background:#d6402e"></span><b style="color:#d6402e">Out of stock</b>
          {%- endif -%}
        </div>

        {%- if is_preorder -%}
          <div class="pdp__preorder">
            <div class="pdp__preorder-h mp-cond">&#128640; Pre-order only</div>
            <div class="pdp__preorder-b">This title hasn&rsquo;t been released yet &mdash; order now to reserve your copy.{% if preorder_eta != blank %} <b>Estimated dispatch: {{ preorder_eta }}.</b>{% endif %} You&rsquo;ll be charged today and we&rsquo;ll ship it as soon as stock arrives.</div>
          </div>
        {%- endif -%}

        {%- comment -%} Out of stock (and not a pre-order) -> swap buy buttons for a Klaviyo back-in-stock trigger. {%- endcomment -%}
        {%- assign show_notify = false -%}
        {%- unless is_preorder or product.available -%}{%- assign show_notify = true -%}{%- endunless -%}

        {%- comment -%} Out of stock -> hide quantity; nothing to add to the basket. {%- endcomment -%}
        <div data-qty-wrap{% if show_notify %} hidden{% endif %}>
          <div class="pdp__qlabel">Quantity</div>
          <div class="pdp__qty">
            <button type="button" data-q="-1" aria-label="Decrease quantity">&minus;</button>
            <input type="number" id="pdp-qty-{{ section.id }}" value="1" min="1" inputmode="numeric">
            <button type="button" data-q="1" aria-label="Increase quantity">+</button>
          </div>
        </div>

        <div class="pdp__actions"{% if show_notify %} hidden{% endif %} data-buy-actions>
          <button type="button" class="pdp__add" data-add="cart"{% unless product.available %} disabled{% endunless %}>{% if is_preorder %}Pre-order now{% else %}Add to basket{% endif %}</button>
        </div>
        <button type="button" class="pdp__buynow" data-add="checkout"{% if show_notify %} hidden{% endif %}{% unless product.available %} disabled{% endunless %}>{% if is_preorder %}Pre-order &amp; checkout{% else %}Buy it now{% endif %}</button>
        <a class="klaviyo-bis-trigger pdp__notify" href="#" data-notify{% unless show_notify %} hidden{% endunless %}>Notify me when available</a>
        <div class="pdp__notify-note" data-notify-note{% unless show_notify %} hidden{% endunless %}>We&rsquo;ll email you the moment it&rsquo;s back in stock.</div>

        {%- comment -%} 3D-printed storage inserts made for this game — quick-add straight to basket {%- endcomment -%}
        {%- assign game_inserts = m.available_inserts.value -%}
        {%- if product.type != 'Board Game Insert' and game_inserts != blank and game_inserts.size > 0 -%}
          <div class="pdp__addon">
            <div class="pdp__addon-h">&#128230; Storage insert{% if game_inserts.size > 1 %}s{% endif %} for this game</div>
            {%- for ins in game_inserts limit: 2 -%}
              {%- comment -%} On a physical game page, prefer the printed (shippable) variant; fall back to whatever's available (e.g. STL-only). {%- endcomment -%}
              {%- assign ins_v = blank -%}
              {%- for v in ins.variants -%}{%- if ins_v == blank and v.available and v.requires_shipping -%}{%- assign ins_v = v -%}{%- endif -%}{%- endfor -%}
              {%- unless ins_v -%}{%- assign ins_v = ins.selected_or_first_available_variant -%}{%- endunless -%}
              <div class="pdp__addon-row">
                <a href="{{ ins.url }}" class="pdp__addon-thumb">{% if ins.featured_image %}<img src="{{ ins.featured_image | image_url: width: 120 }}" alt="{{ ins.title | escape }}" width="120" height="120" loading="lazy">{% endif %}</a>
                <div class="pdp__addon-info">
                  <a href="{{ ins.url }}" class="pdp__addon-name">{{ ins.title }}</a>
                  <div class="pdp__addon-price">{{ ins_v.price | money }}{% if ins.variants.size > 1 %} · {{ ins_v.title }}{% endif %}</div>
                </div>
                {%- if ins_v -%}<button type="button" class="pdp__addon-btn" data-quick-add="{{ ins_v.id }}"{% unless ins.available %} disabled{% endunless %}>Add</button>{%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- comment -%} App blocks (e.g. Judge.me Review Widget) render in the #reviews section below, not here. {%- endcomment -%}

        {%- comment -%} STL/digital variants have requires_shipping = false — swap the physical reassurance for a download notice. Initial state reflects the selected variant; JS retoggles on option change. {%- endcomment -%}
        {%- assign has_digital = false -%}
        {%- for v in product.variants -%}{%- unless v.requires_shipping -%}{%- assign has_digital = true -%}{%- endunless -%}{%- endfor -%}
        <div class="pdp__reassure" data-physical-notice{% if variant.requires_shipping == false %} hidden{% endif %}>
          <span>&#128666; <b>Free UK delivery</b> on orders over £{{ settings.free_shipping_threshold }} · next working day dispatch</span>
          <span>&#8634; <b>30-day returns</b> · unopened &amp; in original condition</span>
          <span>&#9989; <b>100% official UK stock</b> · price-match promise</span>
        </div>
        {%- if has_digital -%}
          <div class="pdp__reassure pdp__digital" data-digital-notice{% unless variant.requires_shipping == false %} hidden{% endunless %}>
            <span>&#11015; <b>Instant digital download</b> · your STL files are delivered by email the moment your order is confirmed — nothing ships</span>
            <span>&#128424; <b>Print it yourself</b> · ready-to-slice STL files for any FDM 3D printer</span>
            <span>&#128274; <b>Personal-use licence</b> · print for your own copies; please don&rsquo;t resell the prints or files</span>
          </div>
        {%- endif -%}

        <div class="pdp__share">
          <span>&#8593; Share</span>
          <span data-sku{% if variant.sku == blank %} hidden{% endif %}>SKU: {{ variant.sku }}</span>
        </div>
      </div>
    </div>

    {%- assign base_game = product.metafields.custom.base_game.value -%}
    {%- if base_game != blank -%}
      {%- if product.metafields.custom.standalone.value -%}
        <div class="pdp__exp-banner">&#129513; <span><strong>This is an expansion of <a href="{{ base_game.url }}">{{ base_game.title }}</a></strong> but it can be played standalone with the base game.</span></div>
      {%- else -%}
        <div class="pdp__exp-banner">&#129513; <span><strong>This is an expansion.</strong> Requires <a href="{{ base_game.url }}">{{ base_game.title }}</a> to play.</span></div>
      {%- endif -%}
    {%- endif -%}

    {%- comment -%} Board Game Insert (fallback template only) -> the game(s) this insert is designed for. The reverse "inserts available" link now lives as a quick-add card in the buy box + the post-add modal. {%- endcomment -%}
    {%- if product.type == 'Board Game Insert' -%}
      {%- assign insert_games = m.insert_for_game.value -%}
      {%- if insert_games != blank and insert_games.size > 0 -%}
        <div class="pdp__insert-banner">&#128230; <span><strong>Storage insert for</strong> {% for g in insert_games %}{%- unless forloop.first -%}{%- if forloop.last -%} &amp; {%- else -%}, {%- endif -%}{%- endunless -%}<a href="{{ g.url }}">{{ g.title }}</a>{% endfor %}</span></div>
      {%- endif -%}
    {%- endif -%}

    <!-- Game at a glance + How to play -->
    <div class="pdp__cols">
      <div class="pdp__left">
        <div class="pdp__h">Game at a glance</div>

        <div class="pdp__ratings">
          {%- if bgg != blank -%}
            {%- assign bggpct = bggn | times: 10 | round -%}
            <div class="pdp__rcell">
              <div class="k">BOARDGAMEGEEK</div>
              <div style="display:flex;align-items:baseline;gap:7px;margin-top:9px"><span class="s">{{ bggdisp }}</span><span class="o">/ 10</span></div>
              <div class="pdp__bar"><span style="width:{{ bggpct }}%;background:{{ bgg_color }}"></span></div>
              <div style="font-size:11.5px;color:#8a8278;margin-top:7px">{% if m.bgg_rank.value != blank %}rank #{{ m.bgg_rank.value }}{% else %}community rating{% endif %}</div>
            </div>
          {%- endif -%}
          {%- if rcount != blank -%}
            <div class="pdp__rcell">
              <div class="k">CUSTOMER REVIEWS</div>
              <div style="display:flex;align-items:baseline;gap:7px;margin-top:9px"><span class="s">{{ rscore }}</span><span class="o">/ 5</span></div>
              <div class="pdp__bar"><span style="width:{{ rscore | times: 20 | round }}%;background:#f2872f"></span></div>
              <div style="font-size:11.5px;color:#8a8278;margin-top:7px">{{ rcount }} verified reviews</div>
            </div>
          {%- endif -%}
          {%- if m.awards.value != blank -%}
            <div class="pdp__rcell" style="background:#faf4e9;border-right:0">
              <div class="k" style="color:#b08a3c">AWARDS</div>
              <div style="display:flex;align-items:center;gap:8px;margin-top:8px"><span style="font-size:20px">&#127942;</span><span style="font-size:14px;font-weight:700;line-height:1.15">{{ m.awards.value }}</span></div>
            </div>
          {%- endif -%}
        </div>

        <div class="pdp__specs">
          {%- if m.player_count.value != blank -%}
            <div class="pdp__spec"><span class="accent" style="background:#2c5466"></span>
              <div style="display:flex;align-items:center;gap:10px"><span class="ico" style="background:#e7eef1">&#128101;</span><span class="k">PLAYERS</span></div>
              <div class="v">{{ m.player_count.value }}</div>
            </div>
          {%- endif -%}
          {%- if m.play_time.value != blank -%}
            <div class="pdp__spec"><span class="accent" style="background:#f2872f"></span>
              <div style="display:flex;align-items:center;gap:10px"><span class="ico" style="background:#fbeadb">&#9201;</span><span class="k">PLAY TIME</span></div>
              <div class="v">{{ m.play_time.value }}</div>
            </div>
          {%- endif -%}
          {%- if m.min_age.value != blank -%}
            <div class="pdp__spec"><span class="accent" style="background:#2f8f5b"></span>
              <div style="display:flex;align-items:center;gap:10px"><span class="ico" style="background:#e3f1e9">&#127919;</span><span class="k">AGE</span></div>
              <div class="v">{{ m.min_age.value }}+</div><div class="vsub">publisher rating</div>
            </div>
          {%- endif -%}
          {%- if show_weight -%}
            <div class="pdp__spec"><span class="accent" style="background:#6a4f86"></span>
              <div style="display:flex;align-items:center;gap:10px"><span class="ico" style="background:#ede7f3">&#129504;</span><span class="k">COMPLEXITY</span></div>
              <div class="v">{{ m.weight.value }} / 5</div>{% if m.complexity.value != blank %}<div class="vsub">{{ m.complexity.value }} weight</div>{% endif %}
            </div>
          {%- endif -%}
          {%- if m.designer.value != blank -%}
            <div class="pdp__spec"><span class="accent" style="background:#16323f"></span>
              <div style="display:flex;align-items:center;gap:10px"><span class="ico" style="background:#e6ecee">&#9997;</span><span class="k">DESIGNER</span></div>
              <div class="v" style="font-size:16px">{{ designer_links }}</div>
            </div>
          {%- endif -%}
          {%- if m.year_published.value != blank -%}
            <div class="pdp__spec"><span class="accent" style="background:#9a3b2e"></span>
              <div style="display:flex;align-items:center;gap:10px"><span class="ico" style="background:#f3e3e0">&#128197;</span><span class="k">YEAR</span></div>
              <div class="v">{{ m.year_published.value }}</div>{% if product.vendor != blank %}<div class="vsub"><a href="/collections/publisher-{{ product.vendor | handle }}">{{ product.vendor }}</a></div>{% endif %}
            </div>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} How-to-play box only when there's a YouTube video; otherwise show just the external links (if any), or nothing at all {%- endcomment -%}
      {%- assign has_howto = false -%}
      {%- if m.youtube_id != blank -%}{%- assign has_howto = true -%}{%- endif -%}
      {%- assign has_gamelinks = false -%}
      {%- if m.bgg_url != blank or m.bga_url != blank -%}{%- assign has_gamelinks = true -%}{%- endif -%}
      {%- if has_howto or has_gamelinks -%}
      <div class="pdp__play">
        {%- if has_howto -%}
          <h2>How to play</h2>
          <div class="pdp__panel" data-panel="how">
            <div class="pdp__embed">
              <iframe src="https://www.youtube-nocookie.com/embed/{{ m.youtube_id }}" title="{{ product.title | escape }} — how to play" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>
            </div>
            <div class="pdp__vidttl">{{ product.title }} — How to Play</div>
            <div style="font-size:12px;color:#9fb4bd;margin-top:2px">Video tutorial · {% if m.video_url != blank %}<a href="{{ m.video_url }}" target="_blank" rel="noopener" style="color:#f2872f;text-decoration:none">more videos</a>{% else %}playthroughs &amp; reviews{% endif %}</div>
          </div>
        {%- else -%}
          <h2>Useful links</h2>
        {%- endif -%}

        {%- if has_gamelinks -%}
        <div class="pdp__ext"{% unless has_howto %} style="border-top:0;margin-top:16px;padding-top:0"{% endunless %}>
          {%- if m.bgg_url != blank -%}<a href="{{ m.bgg_url }}" target="_blank" rel="noopener"><span style="font-size:15px">&#9733;</span><span>View on BGG</span></a>{%- endif -%}
          {%- if m.bga_url != blank -%}<a href="{{ m.bga_url }}" target="_blank" rel="noopener"><span style="font-size:15px">&#9824;</span><span>Play on BGA</span></a>{%- endif -%}
        </div>
        {%- endif -%}
      </div>
      {%- endif -%}
    </div>

    <!-- description + game information -->
    <div class="pdp__cols">
      <div class="pdp__left">
        <div class="pdp__desctabs">
          <button type="button" class="pdp__desctab is-active" data-desc="desc">Description</button>
          {%- if mechanics != blank and mechanics.size > 0 -%}<button type="button" class="pdp__desctab" data-desc="mech">Mechanics</button>{%- endif -%}
          <button type="button" class="pdp__desctab" data-desc="delivery">Delivery &amp; returns</button>
        </div>

        <div class="pdp__descpanel" data-descpanel="desc">
          <div class="pdp__rte">{{ product.description }}</div>
        </div>
        {%- if mechanics != blank and mechanics.size > 0 -%}
          <div class="pdp__descpanel" data-descpanel="mech" hidden>
            <div class="pdp__rte"><p>This game uses the following core mechanisms:</p>
              <p>{% for mech in mechanics %}<a href="/collections/mechanic-{{ mech | handle }}" style="display:inline-block;background:#efe9dd;border-radius:20px;padding:5px 12px;margin:0 6px 8px 0;font-size:13px;font-weight:600;color:#4a443c;text-decoration:none">{{ mech }}</a>{% endfor %}</p>
            </div>
          </div>
        {%- endif -%}
        <div class="pdp__descpanel" data-descpanel="delivery" hidden>
          <div class="pdp__rte">
            <p><b>Free UK delivery</b> on orders over £{{ settings.free_shipping_threshold }}. Orders are dispatched the next working day.</p>
            <p><b>30-day returns</b> on unopened items in their original condition. See our delivery &amp; returns policy for full details.</p>
          </div>
        </div>

        {%- if section.settings.show_features -%}
          <div class="pdp__h" style="font-size:17px;margin:24px 0 12px">Why you'll love it</div>
          <div class="pdp__feats">
            {%- if bgg != blank -%}<div class="pdp__feat"><span class="ok">&#10003;</span> Rated {{ bggdisp }} on BoardGameGeek{% if m.bgg_rank.value != blank %} · ranked #{{ m.bgg_rank.value }}{% endif %}</div>{%- endif -%}
            {%- if m.complexity.value != blank -%}<div class="pdp__feat"><span class="ok">&#10003;</span> {{ m.complexity.value }}-weight — {{ m.play_time.value | default: 'a satisfying play length' }}</div>{%- endif -%}
            {%- if m.player_count.value != blank -%}<div class="pdp__feat"><span class="ok">&#10003;</span> Plays {{ m.player_count.value }} players</div>{%- endif -%}
            <div class="pdp__feat"><span class="ok">&#10003;</span> 100% official UK stock with price-match promise</div>
          </div>
        {%- endif -%}
{%- assign faqs = product.metafields.custom.faqs.value -%}
{%- if faqs != blank and faqs.size > 0 -%}
  <div class="pdp__faq">
    <div class="pdp__h" style="font-size:17px;margin:24px 0 12px">Frequently asked questions</div>
    {%- for f in faqs -%}
      <details class="pdp__faqitem">
        <summary class="pdp__faqq">{{ f.q }}</summary>
        <div class="pdp__faqa">{{ f.a }}</div>
      </details>
    {%- endfor -%}
  </div>
  <style>
    .mp-pdp-{{ section.id }} .pdp__faqitem { border-top: 1px solid #e7ddcb; }
    .mp-pdp-{{ section.id }} .pdp__faqitem:last-of-type { border-bottom: 1px solid #e7ddcb; }
    .mp-pdp-{{ section.id }} .pdp__faqq { cursor: pointer; padding: 13px 4px; font-size: 14px; font-weight: 600; color: #16323f; list-style: none; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
    .mp-pdp-{{ section.id }} .pdp__faqq::-webkit-details-marker { display: none; }
    .mp-pdp-{{ section.id }} .pdp__faqq::after { content: '+'; font-size: 18px; color: #f2872f; font-weight: 700; line-height: 1; }
    .mp-pdp-{{ section.id }} .pdp__faqitem[open] .pdp__faqq::after { content: '\2212'; }
    .mp-pdp-{{ section.id }} .pdp__faqa { padding: 0 4px 14px; font-size: 13.5px; line-height: 1.6; color: #4a443c; }
  </style>
{%- endif -%}
      </div>

      <div class="pdp__info">
        <h3>Game information</h3>
        {%- if m.designer.value != blank -%}<div class="pdp__inforow"><span class="k">Designer</span><span class="v">{{ designer_links }}</span></div>{%- endif -%}
        {%- if m.artist.value != blank -%}<div class="pdp__inforow"><span class="k">Artist</span><span class="v">{{ artist_links }}</span></div>{%- endif -%}
        {%- if product.vendor != blank -%}<div class="pdp__inforow"><span class="k">Publisher</span><span class="v"><a href="/collections/publisher-{{ product.vendor | handle }}">{{ product.vendor }}</a></span></div>{%- endif -%}
        {%- if m.year_published.value != blank -%}<div class="pdp__inforow"><span class="k">Year</span><span class="v">{{ m.year_published.value }}</span></div>{%- endif -%}
        {%- if m.player_count.value != blank -%}<div class="pdp__inforow"><span class="k">Players</span><span class="v">{{ m.player_count.value }}</span></div>{%- endif -%}
        {%- if m.play_time.value != blank -%}<div class="pdp__inforow"><span class="k">Play time</span><span class="v">{{ m.play_time.value }}</span></div>{%- endif -%}
        {%- if m.min_age.value != blank -%}<div class="pdp__inforow"><span class="k">Age</span><span class="v">{{ m.min_age.value }}+</span></div>{%- endif -%}
        {%- if m.bgg_rank.value != blank -%}<div class="pdp__inforow"><span class="k">BGG rank</span><span class="v">#{{ m.bgg_rank.value }}</span></div>{%- endif -%}
        {%- if variant.barcode != blank -%}<div class="pdp__inforow"><span class="k">Barcode</span><span class="v">{{ variant.barcode }}</span></div>{%- endif -%}

        {%- assign has_bars = false -%}
        {%- if show_weight or m.rating_strategy.value != blank or m.rating_luck.value != blank or m.rating_interaction.value != blank -%}{%- assign has_bars = true -%}{%- endif -%}
        {%- if has_bars -%}
          <div class="pdp__bars">
            {%- if show_weight -%}
              <div class="pdp__brow"><div class="bl"><span>Complexity</span><b>{{ m.weight.value }} / 5</b></div><div class="pdp__btrack"><span style="width:{{ m.weight.value | times: 20 | round }}%;background:#9a3b2e"></span></div></div>
            {%- endif -%}
            {%- if m.rating_strategy.value != blank -%}
              <div class="pdp__brow"><div class="bl"><span>Strategy</span><b>{{ m.rating_strategy.value }} / 5</b></div><div class="pdp__btrack"><span style="width:{{ m.rating_strategy.value | times: 20 | round }}%;background:#2c3f8f"></span></div></div>
            {%- endif -%}
            {%- if m.rating_luck.value != blank -%}
              <div class="pdp__brow"><div class="bl"><span>Luck</span><b>{{ m.rating_luck.value }} / 5</b></div><div class="pdp__btrack"><span style="width:{{ m.rating_luck.value | times: 20 | round }}%;background:#3c3a34"></span></div></div>
            {%- endif -%}
            {%- if m.rating_interaction.value != blank -%}
              <div class="pdp__brow"><div class="bl"><span>Interaction</span><b>{{ m.rating_interaction.value }} / 5</b></div><div class="pdp__btrack"><span style="width:{{ m.rating_interaction.value | times: 20 | round }}%;background:#2f8f5b"></span></div></div>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>

    <!-- customer reviews (Judge.me) -->
    <div class="pdp__reviews" id="reviews">
      {%- if section.blocks.size > 0 -%}
        {%- comment -%} Judge.me Review Widget (v3) added as an @app block via Theme editor › Apps. {%- endcomment -%}
        {%- for block in section.blocks -%}
          {%- if block.type == '@app' -%}{% render block %}{%- endif -%}
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} Fallback: legacy manual widget. Note: empty on Judge.me Widget v3 — add the Review Widget app block to populate. {%- endcomment -%}
        <div style="clear:both"></div>
        <div id="judgeme_product_reviews" class="jdgm-widget jdgm-review-widget" data-product-title="{{ product.title | escape }}" data-id="{{ product.id }}"></div>
      {%- endif -%}
    </div>

    <!-- expansions for this game -->
    {%- assign exps = product.metafields.custom.expansions.value -%}
    {%- if exps != blank and exps.size > 0 -%}
      <div class="pdp__also">
        <div class="pdp__alsohead"><div class="pdp__h" style="margin:0">Expansions for {{ product.title }}</div></div>
        <div class="pdp__grid">
          {%- for rec in exps limit: 4 -%}
            {%- liquid
              assign rsale = false
              if rec.compare_at_price > rec.price
                assign rsale = true
                assign rdisc = rec.compare_at_price | minus: rec.price | times: 100.0 | divided_by: rec.compare_at_price | round
              endif
            -%}
            <div class="pdp__card">
              {%- if rsale -%}<span class="cflag">-{{ rdisc }}%</span>{%- endif -%}
              <a href="{{ rec.url }}" class="cmedia">{% if rec.featured_image %}<img src="{{ rec.featured_image | image_url: width: 360 }}" alt="{{ rec.title | escape }}" width="360" height="360" loading="lazy">{% endif %}</a>
              <div class="cbody">
                <a class="cname" href="{{ rec.url }}">{{ rec.title }}</a>
                {%- if rec.vendor != blank -%}<div style="font-size:11.5px;color:#9b948a;margin-top:2px">{{ rec.vendor }}</div>{%- endif -%}
                <div class="cfoot">
                  <div>
                    {%- if rsale -%}<span style="font-size:11px;color:#9b948a;text-decoration:line-through">{{ rec.compare_at_price | money }}</span>{%- endif -%}
                    <div class="cprice">{{ rec.price | money }}</div>
                  </div>
                  <a class="cadd" href="{{ rec.url }}">View</a>
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    <!-- customers also bought -->
    {%- liquid
      assign rel_source = section.settings.related_collection
      if rel_source == blank
        assign rel_source = product.collections.first
      endif
      assign also = rel_source.products
    -%}
    {%- if also.size > 0 -%}
      <div class="pdp__also">
        <div class="pdp__alsohead">
          <div class="pdp__h" style="margin:0">{{ section.settings.also_heading }}</div>
          {%- if rel_source.url -%}<a class="pdp__viewall" href="{{ rel_source.url }}">View all &#8594;</a>{%- endif -%}
        </div>
        <div class="pdp__grid">
          {%- assign shown = 0 -%}
          {%- for rec in also -%}
            {%- if rec.id == product.id -%}{%- continue -%}{%- endif -%}
            {%- if shown >= 4 -%}{%- break -%}{%- endif -%}
            {%- assign shown = shown | plus: 1 -%}
            {%- liquid
              assign rbgg = rec.metafields.custom.bgg_rating.value
              assign rbggn = rbgg | times: 1.0
              assign rbggdisp = rbggn | round: 1
              assign rc = '#e0b441'
              if rbggn >= 8.0
                assign rc = '#5fbf7e'
              elsif rbggn >= 7.0
                assign rc = '#9ccf63'
              endif
              assign rsale = false
              if rec.compare_at_price > rec.price
                assign rsale = true
                assign rdisc = rec.compare_at_price | minus: rec.price | times: 100.0 | divided_by: rec.compare_at_price | round
              endif
            -%}
            <div class="pdp__card">
              {%- if rsale -%}<span class="cflag">-{{ rdisc }}%</span>{%- endif -%}
              <a href="{{ rec.url }}" class="cmedia">{% if rec.featured_image %}<img src="{{ rec.featured_image | image_url: width: 360 }}" alt="{{ rec.title | escape }}" width="360" height="360" loading="lazy">{% endif %}</a>
              <div class="cbody">
                {%- if rbgg != blank -%}
                  <div style="display:flex;align-items:center;gap:6px;margin-bottom:6px">
                    <span style="display:inline-flex;align-items:center;gap:5px;background:#2b2233;border-radius:5px;padding:2px 6px"><span style="font-size:10px;font-weight:700;color:#fff;letter-spacing:.5px">BGG</span><span style="font-size:11px;font-weight:700;color:{{ rc }}">{{ rbggdisp }}</span></span>
                    {%- if rec.metafields.custom.bgg_rank.value != blank -%}<span style="font-size:10.5px;color:#9b948a">rank #{{ rec.metafields.custom.bgg_rank.value }}</span>{%- endif -%}
                  </div>
                {%- endif -%}
                <a class="cname" href="{{ rec.url }}">{{ rec.title }}</a>
                {%- if rec.metafields.custom.player_count.value != blank or rec.metafields.custom.play_time.value != blank -%}
                  <div style="display:flex;gap:10px;margin-top:7px;font-size:11px;color:#6b7a82">
                    {%- if rec.metafields.custom.player_count.value != blank -%}<span>&#9823; {{ rec.metafields.custom.player_count.value }}</span>{%- endif -%}
                    {%- if rec.metafields.custom.play_time.value != blank -%}<span>&#9201; {{ rec.metafields.custom.play_time.value }}</span>{%- endif -%}
                  </div>
                {%- endif -%}
                <div class="cfoot">
                  <div>
                    {%- if rsale -%}<span style="font-size:11px;color:#9b948a;text-decoration:line-through">{{ rec.compare_at_price | money }}</span>{%- endif -%}
                    <div class="cprice">{{ rec.price | money }}</div>
                  </div>
                  <a class="cadd" href="{{ rec.url }}">Add</a>
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

  </div>

  {%- comment -%} Post-add cross-sell modal: expansions + storage inserts for this game. Only rendered when at least one exists (otherwise Add to basket just goes to the cart). {%- endcomment -%}
  {%- assign xp = product.metafields.custom.expansions.value -%}
  {%- assign avins = product.metafields.custom.available_inserts.value -%}
  {%- assign upsell_count = 0 -%}
  {%- if product.type != 'Board Game Insert' -%}
    {%- if xp != blank -%}{%- assign upsell_count = upsell_count | plus: xp.size -%}{%- endif -%}
    {%- if avins != blank -%}{%- assign upsell_count = upsell_count | plus: avins.size -%}{%- endif -%}
  {%- endif -%}
  {%- if upsell_count > 0 -%}
    <div class="pdp__modal" data-upsell-modal hidden role="dialog" aria-modal="true" aria-label="Added to basket">
      <div class="pdp__modal-ov" data-modal-close></div>
      <div class="pdp__modal-panel">
        <button type="button" class="pdp__modal-close" data-modal-close aria-label="Close">&times;</button>
        <span class="pdp__modal-badge">&#10003; Added to your basket</span>
        <div class="pdp__modal-h">Complete your game</div>
        <div class="pdp__modal-sub"><strong>{{ product.title }}</strong> is in your basket. Would you like to add{% if xp != blank and xp.size > 0 %} an expansion{% endif %}{% if xp != blank and xp.size > 0 and avins != blank and avins.size > 0 %} or{% endif %}{% if avins != blank and avins.size > 0 %} a 3D-printed storage insert{% endif %}?</div>
        <div class="pdp__modal-grid">
          {%- if xp != blank -%}{%- for rec in xp limit: 4 -%}
            {%- assign rv = rec.selected_or_first_available_variant -%}
            <div class="pdp__modal-card">
              <span class="pdp__modal-tag pdp__modal-tag--exp">Expansion</span>
              <a href="{{ rec.url }}" class="mc-media">{% if rec.featured_image %}<img src="{{ rec.featured_image | image_url: width: 300 }}" alt="{{ rec.title | escape }}" width="300" height="300" loading="lazy">{% endif %}</a>
              <a href="{{ rec.url }}" class="pdp__modal-name">{{ rec.title }}</a>
              <div class="pdp__modal-foot">
                <span class="pdp__modal-price">{% if rec.price_varies %}from {% endif %}{{ rec.price_min | money }}</span>
                {%- if rv -%}<button type="button" class="pdp__modal-add" data-quick-add="{{ rv.id }}"{% unless rec.available %} disabled{% endunless %}>Add</button>{%- endif -%}
              </div>
            </div>
          {%- endfor -%}{%- endif -%}
          {%- comment -%} storage inserts {%- endcomment -%}
          {%- if avins != blank -%}{%- for rec in avins limit: 4 -%}
            {%- assign rv = blank -%}
            {%- for v in rec.variants -%}{%- if rv == blank and v.available and v.requires_shipping -%}{%- assign rv = v -%}{%- endif -%}{%- endfor -%}
            {%- unless rv -%}{%- assign rv = rec.selected_or_first_available_variant -%}{%- endunless -%}
            <div class="pdp__modal-card">
              <span class="pdp__modal-tag pdp__modal-tag--ins">Storage insert</span>
              <a href="{{ rec.url }}" class="mc-media">{% if rec.featured_image %}<img src="{{ rec.featured_image | image_url: width: 300 }}" alt="{{ rec.title | escape }}" width="300" height="300" loading="lazy">{% endif %}</a>
              <a href="{{ rec.url }}" class="pdp__modal-name">{{ rec.title }}</a>
              <div class="pdp__modal-foot">
                <span class="pdp__modal-price">{{ rv.price | money }}{% if rec.variants.size > 1 %} · {{ rv.title }}{% endif %}</span>
                {%- if rv -%}<button type="button" class="pdp__modal-add" data-quick-add="{{ rv.id }}"{% unless rec.available %} disabled{% endunless %}>Add</button>{%- endif -%}
              </div>
            </div>
          {%- endfor -%}{%- endif -%}
        </div>
        <div class="pdp__modal-actions">
          <a class="go" href="{{ routes.cart_url }}">Go to basket &#8594;</a>
          <button type="button" class="dismiss" data-modal-close>No thanks, keep browsing</button>
        </div>
      </div>
    </div>
  {%- endif -%}
</div>

{%- comment -%} Structured data for search engines (Product + Breadcrumb) {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Product",
      "name": {{ product.title | json }},
      "url": {{ canonical_url | json }},
      {%- assign schema_img = product.featured_image | default: product.media.first.preview_image -%}
      {% if schema_img %}"image": {{ schema_img | image_url: width: 1200 | prepend: "https:" | json }},{% endif %}
      "description": {{ product.description | default: product.title | strip_html | truncatewords: 60 | truncate: 500 | json }},
      {% if product.vendor != blank %}"brand": { "@type": "Brand", "name": {{ product.vendor | json }} },{% endif %}
      {% if variant.sku != blank %}"sku": {{ variant.sku | json }},{% endif %}
      {% if variant.barcode != blank %}"gtin": {{ variant.barcode | json }},{% endif %}
      {% if variant.sku != blank %}"mpn": {{ variant.sku | json }},{% endif %}
      {% if product.type != blank %}"category": {{ product.type | json }},{% endif %}
      {% if weight != blank and weight > 0 %}"weight": { "@type": "QuantitativeValue", "value": {{ weight }}, "unitCode": "KGM" },{% endif %}
      {% if rcount != blank and rscore != blank %}"aggregateRating": { "@type": "AggregateRating", "ratingValue": "{{ rscore }}", "reviewCount": "{{ rcount }}", "bestRating": "5", "worstRating": "1" },{% endif %}
      {% if product.variants.size > 1 %}
      "offers": {
        "@type": "AggregateOffer",
        "priceCurrency": {{ cart.currency.iso_code | json }},
        "lowPrice": {{ product.price_min | divided_by: 100.0 }},
        "highPrice": {{ product.price_max | divided_by: 100.0 }},
        "offerCount": {{ product.variants.size }},
        "availability": "https://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}",
        "url": {{ canonical_url | json }}
      }
      {% else %}
      "offers": {
        "@type": "Offer",
        "priceCurrency": {{ cart.currency.iso_code | json }},
        "price": {{ variant.price | divided_by: 100.0 }},
        "availability": "https://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}",
        "itemCondition": "https://schema.org/NewCondition",
        "url": {{ canonical_url | json }}
      }
      {% endif %}
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": {{ shop.url | append: routes.root_url | json }} }{% if collection %},
        { "@type": "ListItem", "position": 2, "name": {{ collection.title | json }}, "item": {{ shop.url | append: collection.url | json }} }{% endif %},
        { "@type": "ListItem", "position": {% if collection %}3{% else %}2{% endif %}, "name": {{ product.title | json }}, "item": {{ canonical_url | json }} }
      ]
    }{% if faqs and faqs.size > 0 %},
    {
      "@type": "FAQPage",
      "mainEntity": [
        {%- for f in faqs -%}{ "@type": "Question", "name": {{ f.q | json }}, "acceptedAnswer": { "@type": "Answer", "text": {{ f.a | strip_html | json }} } }{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}
      ]
    }{% endif %}
  ]
}
</script>

<script>
  (function () {
    var root = document.currentScript.previousElementSibling;
    if (!root || !root.hasAttribute('data-pdp')) {
      root = document.querySelector('.mp-pdp-{{ section.id }}');
    }
    if (!root) return;

    // gallery thumbnails
    var main = root.querySelector('#pdp-main-{{ section.id }}');
    root.querySelectorAll('.pdp__thumb').forEach(function (t) {
      t.addEventListener('click', function () {
        if (main) main.src = t.getAttribute('data-src');
        root.querySelectorAll('.pdp__thumb').forEach(function (x) { x.classList.remove('is-active'); });
        t.classList.add('is-active');
      });
    });

    // quantity
    var qty = root.querySelector('#pdp-qty-{{ section.id }}');
    root.querySelectorAll('[data-q]').forEach(function (b) {
      b.addEventListener('click', function () {
        var v = parseInt(qty.value, 10) || 1;
        v += parseInt(b.getAttribute('data-q'), 10);
        if (v < 1) v = 1;
        qty.value = v;
      });
    });

    // how-to-play tabs
    function activate(group, attr, val) {
      root.querySelectorAll('[' + attr + ']').forEach(function (el) {
        el.classList.toggle('is-active', el.getAttribute(attr) === val);
      });
      root.querySelectorAll('[' + group + ']').forEach(function (el) {
        el.hidden = el.getAttribute(group) !== val;
      });
    }
    root.querySelectorAll('[data-tab]').forEach(function (t) {
      t.addEventListener('click', function () { activate('data-panel', 'data-tab', t.getAttribute('data-tab')); });
    });
    root.querySelectorAll('[data-desc]').forEach(function (t) {
      t.addEventListener('click', function () { activate('data-descpanel', 'data-desc', t.getAttribute('data-desc')); });
    });

    // variant selection
    var variants = [
      {%- for v in product.variants -%}
        { "id": {{ v.id }}, "options": {{ v.options | json }}, "available": {{ v.available }}, "price_str": {{ v.price | money | json }}, "compare_str": {% if v.compare_at_price > v.price %}{{ v.compare_at_price | money | json }}{% else %}null{% endif %}, "sku": {{ v.sku | json }}, "avail_qty": {% if v.inventory_management and v.inventory_quantity > 0 %}{{ v.inventory_quantity }}{% else %}0{% endif %}, "requires_shipping": {{ v.requires_shipping }} }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ];
    var variantId = {{ variant.id | default: 'null' }};

    var optionGroups = root.querySelectorAll('[data-options] [data-option-index]');
    var priceEl = root.querySelector('[data-price]');
    var rrpEl = root.querySelector('[data-rrp]');
    var saleEl = root.querySelector('[data-saletag]');
    var msrpRrpEl = root.querySelector('[data-msrp-rrp]');
    var msrpSaveEl = root.querySelector('[data-msrp-save]');
    var stockEl = root.querySelector('[data-stock]');
    var skuEl = root.querySelector('[data-sku]');
    var addBtn = root.querySelector('.pdp__add');
    var buyBtn = root.querySelector('.pdp__buynow');
    var buyActions = root.querySelector('[data-buy-actions]');
    var qtyWrap = root.querySelector('[data-qty-wrap]');
    var notifyEl = root.querySelector('[data-notify]');
    var notifyNote = root.querySelector('[data-notify-note]');
    var physNotice = root.querySelector('[data-physical-notice]');
    var digiNotice = root.querySelector('[data-digital-notice]');
    var shipsNote = root.querySelector('[data-ships-note]');
    var isPreorder = {% if is_preorder %}true{% else %}false{% endif %};

    function currentSelections() {
      return Array.prototype.map.call(optionGroups, function (group) {
        var active = group.querySelector('.pdp__opt.is-active');
        return active ? active.getAttribute('data-value') : null;
      });
    }
    function matchVariant(sel) {
      return variants.filter(function (v) {
        return v.options.length === sel.length && v.options.every(function (o, i) { return o === sel[i]; });
      })[0];
    }
    // Swap the buy buttons for the Klaviyo back-in-stock trigger when a variant is out of stock.
    function toggleNotify(oos) {
      var showNotify = oos && !isPreorder;
      if (buyActions) buyActions.hidden = showNotify;
      if (qtyWrap) qtyWrap.hidden = showNotify;
      if (buyBtn) buyBtn.hidden = showNotify;
      if (notifyEl) notifyEl.hidden = !showNotify;
      if (notifyNote) notifyNote.hidden = !showNotify;
    }
    function updateForVariant(v) {
      if (!v) {
        variantId = null;
        if (addBtn) { addBtn.disabled = true; addBtn.textContent = 'Unavailable'; }
        if (buyBtn) buyBtn.disabled = true;
        toggleNotify(false);
        return;
      }
      variantId = v.id;
      if (priceEl) priceEl.innerHTML = v.price_str;
      if (rrpEl) { if (v.compare_str) { rrpEl.innerHTML = v.compare_str; rrpEl.hidden = false; } else { rrpEl.hidden = true; } }
      if (saleEl) saleEl.hidden = !v.compare_str;
      // The MSRP/RRP line stands in only when there's no compare-at sale price.
      if (msrpRrpEl) msrpRrpEl.hidden = !!v.compare_str;
      if (msrpSaveEl) msrpSaveEl.hidden = !!v.compare_str;
      if (skuEl) { if (v.sku) { skuEl.textContent = 'SKU: ' + v.sku; skuEl.hidden = false; } else { skuEl.hidden = true; } }
      if (stockEl) {
        stockEl.innerHTML = isPreorder
          ? '<span class="pdp__dot" style="background:#f2872f"></span><b style="color:#b4560f">Available to pre-order</b>'
          : (v.available
            ? '<span class="pdp__dot" style="background:#2f8f5b"></span><b style="color:#2f8f5b">In stock</b>' + (v.avail_qty > 0 ? '<span style="color:#6b7a82"> · ' + v.avail_qty + ' available</span>' : '')
            : '<span class="pdp__dot" style="background:#d6402e"></span><b style="color:#d6402e">Out of stock</b>');
      }
      if (addBtn) { addBtn.disabled = !v.available; addBtn.textContent = !v.available ? 'Sold out' : (isPreorder ? 'Pre-order now' : 'Add to basket'); }
      if (buyBtn) buyBtn.disabled = !v.available;
      toggleNotify(!v.available);
      var digital = v.requires_shipping === false;
      if (physNotice) physNotice.hidden = digital;
      if (digiNotice) digiNotice.hidden = !digital;
      if (shipsNote) shipsNote.hidden = digital;
      try {
        var url = new URL(window.location.href);
        url.searchParams.set('variant', v.id);
        window.history.replaceState({}, '', url);
      } catch (e) {}
    }
    root.querySelectorAll('[data-option-value]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var group = btn.closest('[data-option-index]');
        if (group) {
          group.querySelectorAll('.pdp__opt').forEach(function (x) { x.classList.remove('is-active'); });
          btn.classList.add('is-active');
        }
        updateForVariant(matchVariant(currentSelections()));
      });
    });

    // shared cart add + live header refresh
    var moneyFormat = {{ shop.money_format | json }};
    function formatMoney(cents, format) {
      function fmt(number, precision, thousands, decimal) {
        precision = precision == null ? 2 : precision;
        thousands = thousands || ','; decimal = decimal || '.';
        if (isNaN(number) || number == null) return '0';
        number = (number / 100).toFixed(precision);
        var parts = number.split('.');
        var whole = parts[0].replace(/(\d)(?=(\d\d\d)+(?!\d))/g, '$1' + thousands);
        return whole + (parts[1] ? decimal + parts[1] : '');
      }
      var m = (format || '').match(/\{\{\s*(\w+)\s*\}\}/);
      if (!m) return format;
      var value;
      switch (m[1]) {
        case 'amount_no_decimals': value = fmt(cents, 0); break;
        case 'amount_with_comma_separator': value = fmt(cents, 2, '.', ','); break;
        case 'amount_no_decimals_with_comma_separator': value = fmt(cents, 0, '.', ','); break;
        case 'amount_with_apostrophe_separator': value = fmt(cents, 2, "'", '.'); break;
        default: value = fmt(cents, 2);
      }
      return format.replace(/\{\{\s*\w+\s*\}\}/, value);
    }
    function refreshCartUI() {
      return fetch('{{ routes.cart_url }}.js', { headers: { 'Accept': 'application/json' } })
        .then(function (r) { return r.json(); })
        .then(function (cart) {
          document.querySelectorAll('[data-cart-summary]').forEach(function (el) {
            el.innerHTML = cart.item_count + ' · ' + formatMoney(cart.total_price, moneyFormat);
          });
        }).catch(function () {});
    }
    function cartAdd(id, quantity) {
      return fetch('{{ routes.cart_add_url }}', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ items: [{ id: id, quantity: quantity || 1 }] })
      }).then(function (r) { return r.json(); }).then(function (res) {
        return refreshCartUI().then(function () { return res; });
      });
    }

    // cross-sell modal (rendered only when there are expansions/inserts)
    var upsellModal = root.querySelector('[data-upsell-modal]');
    function openModal() { if (upsellModal) { upsellModal.hidden = false; document.body.style.overflow = 'hidden'; } }
    function closeModal() { if (upsellModal) { upsellModal.hidden = true; document.body.style.overflow = ''; } }
    if (upsellModal) {
      upsellModal.querySelectorAll('[data-modal-close]').forEach(function (el) { el.addEventListener('click', closeModal); });
      document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && !upsellModal.hidden) closeModal(); });
    }

    // add to cart / buy now (main product)
    root.querySelectorAll('[data-add]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        if (!variantId) return;
        var checkout = btn.getAttribute('data-add') === 'checkout';
        btn.disabled = true;
        cartAdd(variantId, parseInt(qty.value, 10) || 1).then(function () {
          btn.disabled = false;
          if (checkout) { window.location.href = '/checkout'; return; }
          if (upsellModal) { openModal(); }
          else { window.location.href = '{{ routes.cart_url }}'; }
        }).catch(function () { btn.disabled = false; });
      });
    });

    // quick-add buttons: buy-box insert card + modal upsell cards
    root.querySelectorAll('[data-quick-add]').forEach(function (b) {
      b.addEventListener('click', function () {
        var id = b.getAttribute('data-quick-add');
        if (!id || b.classList.contains('is-added')) return;
        var label = b.textContent;
        b.disabled = true; b.textContent = 'Adding…';
        cartAdd(id, 1).then(function () {
          b.textContent = 'Added ✓'; b.classList.add('is-added'); b.disabled = false;
        }).catch(function () { b.disabled = false; b.textContent = label; });
      });
    });
  })();
</script>

{%- comment -%} SEO: VideoObject for the how-to-play video, when available. {%- endcomment -%}
{%- assign yt_id = product.metafields.custom.youtube_id.value -%}
{%- if yt_id != blank -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "VideoObject",
  "name": {{ product.title | append: ' — How to Play' | json }},
  "description": {{ product.title | append: ': gameplay overview and how to play.' | json }},
  "thumbnailUrl": "https://i.ytimg.com/vi/{{ yt_id }}/hqdefault.jpg",
  "embedUrl": "https://www.youtube.com/embed/{{ yt_id }}",
  "contentUrl": "https://www.youtube.com/watch?v={{ yt_id }}",
  "uploadDate": "{{ product.published_at | date: '%Y-%m-%d' }}"
}
</script>
{%- endif -%}

{%- comment -%} SEO: FAQPage rich results from custom.faqs. {%- endcomment -%}
{%- assign faqs = product.metafields.custom.faqs.value -%}
{%- if faqs != blank and faqs.size > 0 -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for f in faqs -%}
    {
      "@type": "Question",
      "name": {{ f.q | json }},
      "acceptedAnswer": { "@type": "Answer", "text": {{ f.a | json }} }
    }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
}
</script>
{%- endif -%}

{% schema %}
{
  "name": "MP Product",
  "settings": [
    { "type": "header", "content": "Buy box" },
    { "type": "text", "id": "delivery_line", "label": "Delivery line", "default": "Free UK delivery over £50" },
    { "type": "checkbox", "id": "show_features", "label": "Show 'Why you'll love it'", "default": true },
    { "type": "paragraph", "content": "Reviews, awards, BGA link & rating bars are read from product metafields (custom.review_score, custom.awards, etc.)." },
    { "type": "header", "content": "Customers also bought" },
    { "type": "text", "id": "also_heading", "label": "Heading", "default": "Customers also bought" },
    { "type": "collection", "id": "related_collection", "label": "Related collection", "info": "Defaults to one of the product's own collections if left empty." }
  ],
  "blocks": [{ "type": "@app" }],
  "enabled_on": { "templates": ["product"] },
  "presets": [
    { "name": "MP Product" }
  ]
}
{% endschema %}
