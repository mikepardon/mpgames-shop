{%- comment -%}
  MPGames header — logo, search, account / wishlist / basket, and mega-nav.
  Imported from Claude Design "MPGames Homepage".
  This section also loads the Barlow web fonts and defines the shared
  `.mp-cond` (condensed) helper class used across all MP* sections.
{%- endcomment -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700&family=Barlow+Semi+Condensed:wght@500;600;700&display=swap" rel="stylesheet">

{%- style -%}
  .mp-cond { font-family: 'Barlow Semi Condensed', ui-sans-serif, sans-serif; }

  /* Global side-scroll guard: nothing may push the page wider than the viewport.
     `clip` (not `hidden`) so it never creates a scroll container that would break
     position: sticky. Internal rails keep their own overflow-x: auto scrolling. */
  html, body { overflow-x: clip; max-width: 100%; }

  /* shared layout helpers used by every MP* homepage section */
  .mp-cream { background: #e9e4da; font-family: 'Barlow', ui-sans-serif, system-ui, sans-serif; max-width: 100%; }
  /* overflow-x: clip stops any full-width rail/grid (e.g. the Top-rated track)
     from pushing the whole page wider than the viewport and causing side-scroll,
     while leaving each rail's own internal horizontal scrolling intact. */
  .mp-col { width: 100%; max-width: 100%; background: #fff; overflow-x: clip; }

  .mp-hd-{{ section.id }} { font-family: 'Barlow', ui-sans-serif, system-ui, sans-serif; }

  /* row 1 */
  .mp-hd-{{ section.id }} .mp-hd__bar { background: #16323f; }
  .mp-hd-{{ section.id }} .mp-hd__in {
    width: 100%;
    padding: 15px 28px; display: flex; align-items: center; gap: 24px;
  }
  .mp-hd-{{ section.id }} .mp-hd__logo {
    font-size: 26px; font-weight: 700; color: #fff; white-space: nowrap;
    letter-spacing: .5px; text-decoration: none; display: flex; align-items: center;
  }
  .mp-hd-{{ section.id }} .mp-hd__logo span { color: #f2872f; }
  .mp-hd-{{ section.id }} .mp-hd__logo img { display: block; width: auto; }
  .mp-hd-{{ section.id }} .mp-hd__logo .mp-hd__logo-mark { display: none; height: 34px; }
  .mp-hd-{{ section.id }} .mp-hd__search {
    flex: 1; display: flex; align-items: center; background: #fff;
    border-radius: 7px; overflow: hidden; min-width: 0;
  }
  .mp-hd-{{ section.id }} .mp-hd__cats {
    padding: 0 13px; font-size: 12.5px; color: #6b7a82;
    border-right: 1px solid #e2ddd4; white-space: nowrap;
  }
  .mp-hd-{{ section.id }} .mp-hd__search input {
    flex: 1; border: 0; outline: 0; padding: 11px 13px; font-size: 13px;
    color: #16323f; font-family: inherit; min-width: 0; background: transparent;
  }
  .mp-hd-{{ section.id }} .mp-hd__search input::placeholder { color: #a39c92; }
  .mp-hd-{{ section.id }} .mp-hd__search button {
    background: #f2872f; color: #fff; padding: 11px 18px; font-size: 13px;
    font-weight: 600; border: 0; cursor: pointer; font-family: inherit; white-space: nowrap;
  }
  .mp-hd-{{ section.id }} .mp-hd__util {
    display: flex; gap: 22px; color: #dce6ea; font-size: 12.5px;
    align-items: center; white-space: nowrap;
  }
  .mp-hd-{{ section.id }} .mp-hd__util a { color: inherit; text-decoration: none; }
  .mp-hd-{{ section.id }} .mp-hd__stack { display: flex; flex-direction: column; line-height: 1.3; }
  .mp-hd-{{ section.id }} .mp-hd__muted { color: #9fb4bd; font-size: 11px; }
  .mp-hd-{{ section.id }} .mp-hd__white { color: #fff; }
  .mp-hd-{{ section.id }} .mp-hd__basket {
    display: inline-flex; align-items: center; gap: 8px; background: #1d4252;
    border: 1px solid #2c5466; border-radius: 7px; padding: 8px 13px;
  }
  .mp-hd-{{ section.id }} .mp-hd__wish { display: flex; align-items: center; gap: 7px; }

  /* row 2 — mega nav */
  .mp-hd-{{ section.id }} .mp-nav { background: #1d4252; position: relative; }
  .mp-hd-{{ section.id }} .mp-nav__in {
    width: 100%; padding: 0 28px; display: flex; gap: 0;
    color: #dce6ea; font-size: 14px; font-weight: 500;
  }
  .mp-hd-{{ section.id }} .mp-nav__item { position: static; display: flex; align-items: center; }
  .mp-hd-{{ section.id }} .mp-nav__top {
    color: #dce6ea; text-decoration: none; padding: 12px 16px; white-space: nowrap;
    display: inline-flex; align-items: center; gap: 6px;
  }
  .mp-hd-{{ section.id }} .mp-nav__top.is-sale { color: #ffd2b0; font-weight: 600; }
  .mp-hd-{{ section.id }} .mp-nav__sale-spacer { margin-left: auto; }
  .mp-hd-{{ section.id }} .mp-nav__caret { font-size: 10px; opacity: .8; }
  .mp-hd-{{ section.id }} .mp-nav__item:hover .mp-nav__top,
  .mp-hd-{{ section.id }} .mp-nav__top:hover { background: #16323f; color: #fff; }

  .mp-hd-{{ section.id }} .mp-mega {
    display: none; position: absolute; left: 0; right: 0; top: 100%; z-index: 60;
    background: #16323f; border-top: 2px solid #f2872f; box-shadow: 0 18px 44px rgba(0,0,0,.4);
  }
  .mp-hd-{{ section.id }} .mp-nav__item:hover .mp-mega { display: block; }
  .mp-hd-{{ section.id }} .mp-mega__in { max-width: 1200px; margin: 0 auto; padding: 26px 28px; display: flex; gap: 34px; }
  .mp-hd-{{ section.id }} .mp-mega__col { flex: 1; min-width: 0; }
  .mp-hd-{{ section.id }} .mp-mega__h {
    color: #fff; font-size: 13px; font-weight: 700; letter-spacing: .6px; text-transform: uppercase;
    border-bottom: 1px solid #25434f; padding-bottom: 9px; margin-bottom: 10px;
  }
  .mp-hd-{{ section.id }} .mp-mega__grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 0 26px; }
  .mp-hd-{{ section.id }} .mp-mega__link { display: block; color: #9fb4bd; text-decoration: none; font-size: 13.5px; padding: 6px 0; }
  .mp-hd-{{ section.id }} .mp-mega__link:hover { color: #f2872f; }
  .mp-hd-{{ section.id }} .mp-mega__all { display: inline-block; margin-top: 9px; color: #f2872f; font-weight: 600; font-size: 12.5px; text-decoration: none; }
  .mp-hd-{{ section.id }} .mp-mega__feature {
    width: 270px; flex: none; margin-left: auto; background: #0f242e; border: 1px solid #25434f;
    border-radius: 12px; padding: 16px; text-align: center;
  }
  .mp-hd-{{ section.id }} .mp-mega__feyebrow { color: #f2872f; font-size: 10.5px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; margin-bottom: 7px; }
  .mp-hd-{{ section.id }} .mp-mega__fh { color: #fff; font-weight: 700; font-size: 15px; line-height: 1.2; }
  .mp-hd-{{ section.id }} .mp-mega__fsub { color: #9fb4bd; font-size: 12px; margin-top: 3px; }
  .mp-hd-{{ section.id }} .mp-mega__fprice { color: #f2872f; font-weight: 700; font-size: 19px; margin-top: 8px; }
  .mp-hd-{{ section.id }} .mp-mega__fimg { display: block; margin: 11px 0; border-radius: 8px; overflow: hidden; background: #dfd9cd; aspect-ratio: 1/1; }
  .mp-hd-{{ section.id }} .mp-mega__fimg img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .mp-hd-{{ section.id }} .mp-mega__feature form { margin: 0; }
  .mp-hd-{{ section.id }} .mp-mega__fadd { width: 100%; background: #f2872f; color: #fff; border: 0; border-radius: 8px; padding: 11px; font-weight: 700; cursor: pointer; font-family: inherit; font-size: 13.5px; }

  /* mobile drawer chrome (hidden on desktop) */
  .mp-hd-{{ section.id }} .mp-hd__burger {
    display: none; align-items: center; justify-content: center; flex: none;
    width: 40px; height: 40px; margin-right: 2px; padding: 0; cursor: pointer;
    background: #1d4252; border: 1px solid #2c5466; border-radius: 8px; color: #fff; font-size: 17px;
  }
  .mp-hd-{{ section.id }} .mp-mnav__bar { display: none; }
  .mp-hd-{{ section.id }} .mp-nav__backdrop { display: none; }

  @media (max-width: 989px) {
    .mp-hd-{{ section.id }} .mp-hd__util .mp-hd__stack span:first-child,
    .mp-hd-{{ section.id }} .mp-hd__muted { display: none; }
    .mp-hd-{{ section.id }} .mp-hd__burger { display: inline-flex; }

    /* nav becomes an off-canvas drawer */
    .mp-hd-{{ section.id }} .mp-nav {
      position: fixed; top: 0; left: 0; bottom: 0; width: 86%; max-width: 340px; z-index: 210;
      background: #16323f; overflow-y: auto; -webkit-overflow-scrolling: touch;
      transform: translateX(-100%); transition: transform .25s ease; visibility: hidden;
    }
    .mp-hd-{{ section.id }}.is-mopen .mp-nav { transform: translateX(0); visibility: visible; }
    .mp-hd-{{ section.id }} .mp-mnav__bar {
      display: flex; align-items: center; justify-content: space-between;
      padding: 15px 18px; border-bottom: 1px solid #25434f; color: #fff; font-size: 15px; font-weight: 700; letter-spacing: .4px;
    }
    .mp-hd-{{ section.id }} .mp-mnav__bar button { background: none; border: 0; color: #9fb4bd; font-size: 26px; line-height: 1; cursor: pointer; padding: 0 4px; }
    .mp-hd-{{ section.id }} .mp-nav__in { flex-direction: column; align-items: stretch; padding: 6px 0 30px; gap: 0; overflow: visible; }
    .mp-hd-{{ section.id }} .mp-nav__item { display: block; }
    .mp-hd-{{ section.id }} .mp-nav__top { padding: 15px 20px; justify-content: space-between; border-bottom: 1px solid #1d3640; width: 100%; box-sizing: border-box; }
    .mp-hd-{{ section.id }} .mp-nav__caret { display: inline; transition: transform .2s ease; }
    .mp-hd-{{ section.id }} .mp-nav__item.is-open > .mp-nav__top .mp-nav__caret { transform: rotate(180deg); }

    /* mega turns into inline accordion content */
    .mp-hd-{{ section.id }} .mp-mega { position: static; display: none !important; box-shadow: none; border-top: 0; background: #12292f; }
    .mp-hd-{{ section.id }} .mp-nav__item.is-open .mp-mega { display: block !important; }
    .mp-hd-{{ section.id }} .mp-mega__in { flex-direction: column; gap: 10px; max-width: none; margin: 0; padding: 10px 20px 18px; }
    .mp-hd-{{ section.id }} .mp-mega__feature { display: none; }
    .mp-hd-{{ section.id }} .mp-mega__grid { grid-template-columns: 1fr 1fr; gap: 0 18px; }
    .mp-hd-{{ section.id }} .mp-mega__h { border-bottom-color: #1d3640; }

    /* backdrop */
    .mp-hd-{{ section.id }} .mp-nav__backdrop {
      display: block; position: fixed; inset: 0; z-index: 205; background: rgba(9,20,26,.55);
      opacity: 0; pointer-events: none; transition: opacity .25s ease;
    }
    .mp-hd-{{ section.id }}.is-mopen .mp-nav__backdrop { opacity: 1; pointer-events: auto; }
  }
  @media (max-width: 749px) {
    .mp-hd-{{ section.id }} .mp-hd__in { flex-wrap: wrap; gap: 12px; padding: 12px 16px; }
    .mp-hd-{{ section.id }} .mp-hd__search { order: 3; flex: 1 0 100%; }
    .mp-hd-{{ section.id }} .mp-hd__cats { display: none; }
    .mp-hd-{{ section.id }} .mp-hd__util { margin-left: auto; gap: 16px; }
    .mp-hd-{{ section.id }} .mp-hd__wish span:last-child { display: none; }
    .mp-hd-{{ section.id }} .mp-nav__in { padding: 0 16px; }
    .mp-hd-{{ section.id }} .mp-hd__logo .mp-hd__logo-full { display: none; }
    .mp-hd-{{ section.id }} .mp-hd__logo .mp-hd__logo-mark { display: block; }
  }
{%- endstyle -%}

<div class="mp-hd-{{ section.id }}">
  <!-- row 1 -->
  <div class="mp-hd__bar">
    <div class="mp-hd__in">
      <button type="button" class="mp-hd__burger" data-burger aria-label="Open menu" aria-expanded="false" aria-controls="mp-nav-{{ section.id }}">&#9776;</button>
      <a class="mp-hd__logo mp-cond" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | image_url: width: 600 }}" alt="{{ shop.name | escape }}" width="200" height="{{ section.settings.logo_height }}" style="height:{{ section.settings.logo_height }}px">
        {%- else -%}
          <img class="mp-hd__logo-full" src="{{ 'MPGames-logo.png' | asset_url }}" alt="{{ shop.name | escape }}" width="200" height="{{ section.settings.logo_height | default: 34 }}" style="height:{{ section.settings.logo_height | default: 34 }}px">
          <img class="mp-hd__logo-mark" src="{{ 'MPGames-mark.png' | asset_url }}" alt="{{ shop.name | escape }}" width="34" height="34">
        {%- endif -%}
      </a>

      <form action="{{ routes.search_url }}" method="get" role="search" class="mp-hd__search">
        <input type="hidden" name="type" value="product">
        <input type="hidden" name="options[prefix]" value="last">
        <input type="search" name="q" placeholder="{{ section.settings.search_placeholder }}" aria-label="Search">
        <button type="submit">Search</button>
      </form>

      <div class="mp-hd__util">
        <a href="{{ routes.account_url }}" class="mp-hd__stack">
          {%- if customer -%}
            <span class="mp-hd__muted">{% if customer.first_name != blank %}Hello{% else %}Account{% endif %}</span>
            <span class="mp-hd__white">{{ customer.first_name | default: 'My account' }} &#9662;</span>
          {%- else -%}
            <span class="mp-hd__muted">Account</span>
            <span class="mp-hd__white">Sign in &#9662;</span>
          {%- endif -%}
        </a>
        <a href="{{ routes.cart_url }}" class="mp-hd__basket">
          <span>&#128722;</span>
          <span class="mp-hd__stack">
            <span class="mp-hd__muted">Basket</span>
            <span class="mp-hd__white" style="font-weight:600" data-cart-summary>{{ cart.item_count }} &middot; {{ cart.total_price | money }}</span>
          </span>
        </a>
      </div>
    </div>
  </div>

  <!-- row 2 — mega nav -->
  {%- assign mp_menu = linklists[section.settings.menu] -%}
  {%- assign featured = all_products[section.settings.featured_product] -%}
  <nav class="mp-nav mp-cond" id="mp-nav-{{ section.id }}" aria-label="Primary">
    <div class="mp-mnav__bar"><span>Menu</span><button type="button" data-mnav-close aria-label="Close menu">&times;</button></div>
    <div class="mp-nav__in">
      {%- if section.settings.menu != blank and mp_menu.links.size > 0 -%}
        {%- for link in mp_menu.links -%}
          {%- assign lt = link.title | downcase -%}
          {%- assign auto_kind = '' -%}
          {%- if lt contains 'designer' -%}{%- assign auto_kind = 'designer' -%}{%- elsif lt contains 'artist' -%}{%- assign auto_kind = 'artist' -%}{%- elsif lt contains 'publisher' or lt contains 'vendor' or lt contains 'brand' -%}{%- assign auto_kind = 'vendor' -%}{%- elsif lt contains 'shop' -%}{%- assign auto_kind = 'category' -%}{%- endif -%}
          {%- comment -%} Prefix + label to strip + "Shop all" target page per panel. {%- endcomment -%}
          {%- assign auto_prefix = '' -%}
          {%- assign auto_strip = '' -%}
          {%- assign auto_page = link.url -%}
          {%- assign auto_all_label = 'all' -%}
          {%- if auto_kind == 'designer' -%}{%- assign auto_prefix = 'designer-' -%}{%- assign auto_strip = 'Designer:' -%}{%- assign auto_page = '/pages/designers' -%}{%- assign auto_all_label = 'designers' -%}
          {%- elsif auto_kind == 'artist' -%}{%- assign auto_prefix = 'artist-' -%}{%- assign auto_strip = 'Artist:' -%}{%- assign auto_page = '/pages/artists' -%}{%- assign auto_all_label = 'artists' -%}
          {%- elsif auto_kind == 'vendor' -%}{%- assign auto_prefix = 'publisher-' -%}{%- assign auto_strip = 'Publisher:' -%}{%- assign auto_page = '/pages/publishers' -%}{%- assign auto_all_label = 'publishers' -%}
          {%- elsif auto_kind == 'category' -%}{%- assign auto_prefix = 'category-' -%}{%- assign auto_all_label = 'categories' -%}{%- endif -%}
          {%- capture auto_links -%}
            {%- if auto_prefix != blank -%}
              {%- comment -%} Real collections only, ordered by game count (desc), capped at 21 for the creator panels. {%- endcomment -%}
              {%- assign nav_rows = '' -%}
              {%- for c in collections -%}
                {%- if c.handle contains auto_prefix and c.all_products_count > 0 -%}
                  {%- assign nav_pad = '00' | append: c.all_products_count | slice: -3, 3 -%}
                  {%- assign nav_nm = c.title -%}
                  {%- if auto_strip != blank -%}{%- assign nav_nm = nav_nm | remove_first: auto_strip | strip -%}{%- endif -%}
                  {%- assign nav_rows = nav_rows | append: nav_pad | append: '§' | append: nav_nm | append: '§' | append: c.url | append: '¶' -%}
                {%- endif -%}
              {%- endfor -%}
              {%- assign nav_list = nav_rows | split: '¶' | sort | reverse -%}
              {%- assign nav_shown = 0 -%}
              {%- for row in nav_list -%}
                {%- if row == blank -%}{%- continue -%}{%- endif -%}
                {%- if auto_kind != 'category' and nav_shown >= 21 -%}{%- break -%}{%- endif -%}
                {%- assign np = row | split: '§' -%}
                <a class="mp-mega__link" href="{{ np[2] }}">{{ np[1] }}</a>
                {%- assign nav_shown = nav_shown | plus: 1 -%}
              {%- endfor -%}
            {%- endif -%}
          {%- endcapture -%}
          {%- comment -%} Vary the featured card per panel so the same product doesn't repeat across menus.
             Designer/Artist/Publisher panels feature a real game from that family; others use the merchandised pick. {%- endcomment -%}
          {%- assign panel_feature = featured -%}
          {%- assign panel_eyebrow = "Editor's pick" -%}
          {%- if auto_kind == 'designer' or auto_kind == 'artist' or auto_kind == 'vendor' -%}
            {%- assign cprefix = auto_kind -%}
            {%- if auto_kind == 'vendor' -%}{%- assign cprefix = 'publisher' -%}{%- endif -%}
            {%- for c in collections -%}
              {%- if c.handle contains cprefix and c.all_products_count > 0 -%}
                {%- assign cand = c.products.first -%}
                {%- if cand != blank -%}
                  {%- assign panel_feature = cand -%}
                  {%- if auto_kind == 'designer' -%}{%- assign panel_eyebrow = 'Featured designer' -%}{%- elsif auto_kind == 'artist' -%}{%- assign panel_eyebrow = 'Featured artist' -%}{%- else -%}{%- assign panel_eyebrow = 'Featured publisher' -%}{%- endif -%}
                {%- endif -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
          {%- if link.links.size > 0 -%}
            <div class="mp-nav__item">
              <a class="mp-nav__top" href="{{ link.url }}">{{ link.title }} <span class="mp-nav__caret">&#9662;</span></a>
              <div class="mp-mega">
                <div class="mp-mega__in">
                  {%- for col in link.links -%}
                    <div class="mp-mega__col">
                      <div class="mp-mega__h">{{ col.title }}</div>
                      {%- for sub in col.links -%}
                        <a class="mp-mega__link" href="{{ sub.url }}">{{ sub.title }}</a>
                      {%- endfor -%}
                      {%- if col.url != blank and col.url != '/' -%}
                        <a class="mp-mega__all" href="{{ col.url }}">Shop all &raquo;</a>
                      {%- endif -%}
                    </div>
                  {%- endfor -%}
                  {%- render 'mp-mega-feature', feature: panel_feature, eyebrow: panel_eyebrow -%}
                </div>
              </div>
            </div>
          {%- elsif auto_links != blank -%}
            <div class="mp-nav__item">
              <a class="mp-nav__top" href="{{ link.url }}">{{ link.title }} <span class="mp-nav__caret">&#9662;</span></a>
              <div class="mp-mega">
                <div class="mp-mega__in">
                  <div class="mp-mega__col">
                    <div class="mp-mega__h">{% if auto_kind == 'designer' %}Shop by designer{% elsif auto_kind == 'artist' %}Shop by artist{% elsif auto_kind == 'vendor' %}Shop by publisher{% else %}Shop by category{% endif %}</div>
                    <div class="mp-mega__grid">{{ auto_links }}</div>
                    <a class="mp-mega__all" href="{{ auto_page }}">View all {{ auto_all_label }} &raquo;</a>
                  </div>
                  {%- render 'mp-mega-feature', feature: panel_feature, eyebrow: panel_eyebrow -%}
                </div>
              </div>
            </div>
          {%- else -%}
            <a class="mp-nav__top{% if link.title == 'Sale' %} is-sale{% endif %}" href="{{ link.url }}">{{ link.title }}</a>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        <a class="mp-nav__top" href="{{ section.settings.all_url | default: '/collections/all-games' }}">All Games</a>
        <a class="mp-nav__top" href="/collections/new-releases">New In</a>
        <a class="mp-nav__top" href="/collections/cat-strategy">Strategy</a>
        <a class="mp-nav__top" href="/collections/cat-family">Family</a>
        <a class="mp-nav__top" href="/collections/players-2">2-Player</a>
        <a class="mp-nav__top is-sale" href="{{ section.settings.sale_url | default: '/collections/sale' }}">Sale</a>
      {%- endif -%}
    </div>
  </nav>
  <div class="mp-nav__backdrop" data-mnav-backdrop></div>
</div>

<script>
  (function () {
    var root = document.querySelector('.mp-hd-{{ section.id }}');
    if (!root) return;
    var mq = window.matchMedia('(max-width: 989px)');
    var burger = root.querySelector('[data-burger]');
    function open() { root.classList.add('is-mopen'); if (burger) burger.setAttribute('aria-expanded', 'true'); document.body.style.overflow = 'hidden'; }
    function close() { root.classList.remove('is-mopen'); if (burger) burger.setAttribute('aria-expanded', 'false'); document.body.style.overflow = ''; }
    if (burger) burger.addEventListener('click', open);
    root.querySelectorAll('[data-mnav-close], [data-mnav-backdrop]').forEach(function (el) { el.addEventListener('click', close); });
    root.querySelectorAll('.mp-nav__item > .mp-nav__top').forEach(function (a) {
      a.addEventListener('click', function (e) {
        if (mq.matches) { e.preventDefault(); a.parentElement.classList.toggle('is-open'); }
      });
    });
    mq.addEventListener('change', function (e) { if (!e.matches) close(); });
  })();
</script>

{% schema %}
{
  "name": "MP Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo", "info": "Defaults to the bundled MPGames-logo.png asset." },
    { "type": "range", "id": "logo_height", "min": 22, "max": 56, "step": 2, "unit": "px", "label": "Logo height", "default": 34 },
    { "type": "text", "id": "search_placeholder", "label": "Search placeholder", "default": "Search games, designers, publishers…" },
    { "type": "link_list", "id": "menu", "label": "Mega-nav menu", "info": "Leave empty to use the built-in real-collection links." },
    { "type": "url", "id": "all_url", "label": "All Games link", "info": "Defaults to /collections/all-games." },
