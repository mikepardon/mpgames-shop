{%- comment -%}
  MPGames article page — header, hero, prose body, sidebar (games in this guide),
  tags, author bio, related articles. Imported from Claude Design "MPGames Article".
{%- endcomment -%}

{%- liquid
  assign words = article.content | strip_html | split: ' ' | size
  assign read = words | divided_by: 200 | plus: 1
  assign parts = article.author | split: ' '
  assign guide = article.metafields.custom.guide_products.value

  # Build a table of contents from <h2> headings and inject anchor ids.
  assign content_parts = article.content | split: '<h2'
  assign rebuilt = content_parts | first
  assign toc = ''
  assign hcount = 0
  for chunk in content_parts offset: 1
    assign before = chunk | split: '</h2>' | first
    assign htext = before | split: '>' | last | strip_html | strip
    assign hid = htext | handleize | append: '-' | append: forloop.index
    assign rebuilt = rebuilt | append: '<h2 id="' | append: hid | append: '"' | append: chunk
    assign toc = toc | append: '<a class="ar__tocitem" href="#' | append: hid | append: '">' | append: htext | append: '</a>'
    assign hcount = hcount | plus: 1
  endfor
-%}

{%- style -%}
  .mp-ar-{{ section.id }} { background: #f4efe6; font-family: 'Barlow', ui-sans-serif, system-ui, sans-serif; color: #16323f; }
  .mp-ar-{{ section.id }} .ar__crumb { max-width: 1100px; margin: 0 auto; padding: 15px 28px 0; font-size: 12px; color: #9b948a; }
  .mp-ar-{{ section.id }} .ar__crumb a { color: #9b948a; text-decoration: none; }
  .mp-ar-{{ section.id }} .ar__crumb .sep { color: #cfc9be; margin: 0 5px; }

  .mp-ar-{{ section.id }} .ar__head { max-width: 760px; margin: 0 auto; padding: 22px 28px 8px; text-align: center; }
  .mp-ar-{{ section.id }} .ar__tag { font-size: 12px; font-weight: 600; color: #f2872f; letter-spacing: 1px; text-transform: uppercase; }
  .mp-ar-{{ section.id }} .ar__h1 { font-size: 42px; font-weight: 700; margin: 12px 0 0; line-height: 1.08; }
  .mp-ar-{{ section.id }} .ar__ex { font-size: 16px; color: #6b6b62; line-height: 1.6; margin-top: 14px; }
  .mp-ar-{{ section.id }} .ar__by { display: flex; align-items: center; justify-content: center; gap: 13px; margin-top: 22px; flex-wrap: wrap; }
  .mp-ar-{{ section.id }} .ar__av { width: 42px; height: 42px; border-radius: 50%; background: #e6e2da; display: flex; align-items: center; justify-content: center; font-size: 14px; color: #8a8278; text-transform: uppercase; }
  .mp-ar-{{ section.id }} .ar__byline { text-align: left; font-size: 13px; color: #8a8278; }
  .mp-ar-{{ section.id }} .ar__byline b { color: #16323f; }
  .mp-ar-{{ section.id }} .ar__sep { width: 1px; height: 30px; background: #ddd6c8; }
  .mp-ar-{{ section.id }} .ar__share { display: inline-flex; align-items: center; gap: 7px; border: 1px solid #d8d4cc; border-radius: 7px; padding: 8px 13px; font-size: 12.5px; color: #6b7a82; background: none; cursor: pointer; font-family: inherit; }

  .mp-ar-{{ section.id }} .ar__hero { max-width: 980px; margin: 24px auto 0; padding: 0 28px; }
  .mp-ar-{{ section.id }} .ar__heroimg { border-radius: 14px; overflow: hidden; background: repeating-linear-gradient(45deg,#e6e0d4,#e6e0d4 14px,#ded7c9 14px,#ded7c9 28px); aspect-ratio: 16/8; background-size: cover; background-position: center; }

  .mp-ar-{{ section.id }} .ar__body { display: flex; gap: 40px; max-width: 980px; margin: 0 auto; padding: 30px 28px; align-items: flex-start; }
  .mp-ar-{{ section.id }} .ar__prose { flex: 1; min-width: 0; font-size: 16.5px; line-height: 1.75; color: #33312b; }
  .mp-ar-{{ section.id }} .ar__prose > p { margin: 0 0 17px; }
  .mp-ar-{{ section.id }} .ar__prose h2 { font-family: 'Barlow Semi Condensed', sans-serif; font-size: 25px; font-weight: 700; color: #16323f; margin: 30px 0 10px; }
  .mp-ar-{{ section.id }} .ar__prose h3 { font-size: 20px; font-weight: 700; color: #16323f; margin: 24px 0 8px; }
  .mp-ar-{{ section.id }} .ar__prose a { color: #c2410c; }
  .mp-ar-{{ section.id }} .ar__prose img { max-width: 100%; height: auto; border-radius: 10px; margin: 18px 0; }
  .mp-ar-{{ section.id }} .ar__prose ul, .mp-ar-{{ section.id }} .ar__prose ol { padding-left: 22px; margin: 0 0 17px; }
  .mp-ar-{{ section.id }} .ar__prose li { margin-bottom: 7px; }
  .mp-ar-{{ section.id }} .ar__prose blockquote { border-left: 4px solid #f2872f; padding: 6px 0 6px 22px; margin: 24px 0; font-family: 'Barlow Semi Condensed', sans-serif; font-size: 22px; font-weight: 600; color: #16323f; font-style: italic; }

  .mp-ar-{{ section.id }} .ar__tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 28px; padding-top: 22px; border-top: 1px solid #e2ddd1; }
  .mp-ar-{{ section.id }} .ar__tagpill { background: #eef0ec; border-radius: 20px; padding: 6px 13px; font-size: 12px; color: #4a443c; text-decoration: none; }
  .mp-ar-{{ section.id }} .ar__bio { display: flex; gap: 16px; align-items: flex-start; background: #fff; border: 1px solid #e7ddcb; border-radius: 13px; padding: 20px; margin-top: 24px; }
  .mp-ar-{{ section.id }} .ar__biav { width: 52px; height: 52px; border-radius: 50%; background: #e6e2da; display: flex; align-items: center; justify-content: center; font-size: 16px; color: #8a8278; flex: none; text-transform: uppercase; }
  .mp-ar-{{ section.id }} .ar__bin { font-size: 16px; font-weight: 700; color: #16323f; }
  .mp-ar-{{ section.id }} .ar__bir { font-size: 12px; color: #9b948a; margin-bottom: 6px; }
  .mp-ar-{{ section.id }} .ar__bib { font-size: 13.5px; color: #6b6b62; line-height: 1.55; }

  .mp-ar-{{ section.id }} .ar__side { width: 240px; flex: none; position: sticky; top: 16px; }
  .mp-ar-{{ section.id }} .ar__toc { padding: 4px 6px 12px; }
  .mp-ar-{{ section.id }} .ar__tocitem { display: block; padding: 8px 12px; font-size: 13px; color: #4a443c; text-decoration: none; border-left: 2px solid transparent; }
  .mp-ar-{{ section.id }} .ar__tocitem:hover { color: #f2872f; border-left-color: #f2872f; }
  .mp-ar-{{ section.id }} .ar__prose h2 { scroll-margin-top: 16px; }
  .mp-ar-{{ section.id }} .ar__panel { border: 1px solid #e7ddcb; border-radius: 12px; background: #fff; overflow: hidden; box-shadow: 0 1px 2px rgba(20,40,50,.04); }
  .mp-ar-{{ section.id }} .ar__ph { font-size: 14px; font-weight: 700; padding: 15px 16px 11px; }
  .mp-ar-{{ section.id }} .ar__game { text-decoration: none; display: flex; gap: 11px; align-items: center; padding: 11px 16px; border-top: 1px solid #f1ece2; }
  .mp-ar-{{ section.id }} .ar__gimg { width: 42px; height: 42px; border-radius: 7px; flex: none; background: #efece6 center/cover; }
  .mp-ar-{{ section.id }} .ar__gn { display: block; font-size: 13px; font-weight: 600; color: #16323f; }
  .mp-ar-{{ section.id }} .ar__gm { font-size: 11.5px; color: #9b948a; }

  .mp-ar-{{ section.id }} .ar__keep { padding: 14px 28px 34px; max-width: 1100px; margin: 0 auto; }
  .mp-ar-{{ section.id }} .ar__kh { font-size: 22px; font-weight: 700; margin-bottom: 16px; }
  .mp-ar-{{ section.id }} .ar__kgrid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; }
  .mp-ar-{{ section.id }} .ar__kcard { text-decoration: none; border: 1px solid #e7ddcb; border-radius: 12px; overflow: hidden; background: #fff; display: flex; flex-direction: column; box-shadow: 0 1px 2px rgba(20,40,50,.04); }
  .mp-ar-{{ section.id }} .ar__kimg { height: 150px; position: relative; background: repeating-linear-gradient(45deg,#efece6,#efece6 9px,#e6e2da 9px,#e6e2da 18px); background-size: cover; background-position: center; }
  .mp-ar-{{ section.id }} .ar__ktag { position: absolute; top: 10px; left: 10px; background: rgba(22,50,63,.9); color: #fff; font-size: 11px; font-weight: 600; padding: 3px 9px; border-radius: 5px; }
  .mp-ar-{{ section.id }} .ar__kbody { padding: 14px 16px 16px; }
  .mp-ar-{{ section.id }} .ar__kt { font-size: 16px; font-weight: 700; line-height: 1.22; }
  .mp-ar-{{ section.id }} .ar__km { font-size: 11.5px; color: #9b948a; margin-top: 8px; }

  @media (max-width: 899px) {
    .mp-ar-{{ section.id }} .ar__body { flex-direction: column; }
    .mp-ar-{{ section.id }} .ar__side { width: 100%; }
    .mp-ar-{{ section.id }} .ar__h1 { font-size: 32px; }
    .mp-ar-{{ section.id }} .ar__kgrid { grid-template-columns: 1fr; }
  }
{%- endstyle -%}

<section class="mp-ar-{{ section.id }}" data-article>
  <div class="ar__crumb">
    <a href="{{ blog.url }}">{{ blog.title }}</a>
    {%- if article.tags.first -%}<span class="sep">/</span>{{ article.tags.first }}{%- endif -%}
    <span class="sep">/</span><span style="color:#6b7a82">{{ article.title | truncate: 40 }}</span>
  </div>

  <div class="ar__head">
    {%- if article.tags.first -%}<div class="ar__tag mp-cond">{{ article.tags.first }}</div>{%- endif -%}
    <h1 class="ar__h1 mp-cond">{{ article.title }}</h1>
    {%- if article.excerpt != blank -%}<div class="ar__ex">{{ article.excerpt | strip_html }}</div>{%- endif -%}
    <div class="ar__by">
      <button type="button" class="ar__share" data-share>&#8593; Share</button>
    </div>
  </div>

  {%- if article.image -%}
    <div class="ar__hero">
      <div class="ar__heroimg" style="background-image:url('{{ article.image | image_url: width: 1600 }}')"></div>
    </div>
  {%- endif -%}

  <div class="ar__body">
    <article class="ar__prose">
      {{ rebuilt }}

      {%- if article.tags.size > 0 -%}
        <div class="ar__tags">
          {%- for tag in article.tags -%}
            <a class="ar__tagpill" href="{{ blog.url }}/tagged/{{ tag | handleize }}">#{{ tag | handleize }}</a>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="ar__bio">
        <span class="ar__biav">{{ parts.first | slice: 0 }}{{ parts.last | slice: 0 }}</span>
        <div>
          <div class="ar__bin mp-cond">{{ article.author }}</div>
          <div class="ar__bir">{{ section.settings.author_role }}</div>
          <div class="ar__bib">{{ section.settings.author_bio }}</div>
        </div>
      </div>
    </article>

    <aside class="ar__side">
      {%- if hcount >= 2 -%}
        <div class="ar__panel" style="margin-bottom:18px">
          <div class="ar__ph mp-cond">In this article</div>
          <div class="ar__toc">{{ toc }}</div>
        </div>
      {%- endif -%}

      {%- if guide != blank and guide.size > 0 -%}
        <div class="ar__panel">
          <div class="ar__ph mp-cond">Games in this guide</div>
          {%- for g in guide -%}
            <a class="ar__game" href="{{ g.url }}">
              <span class="ar__gimg"{% if g.featured_image %} style="background-image:url('{{ g.featured_image | image_url: width: 90 }}')"{% endif %}></span>
              <span style="flex:1">
                <span class="ar__gn mp-cond">{{ g.title }}</span>
                <span class="ar__gm">{% if g.metafields.custom.bgg_rating.value %}BGG {{ g.metafields.custom.bgg_rating.value }} · {% endif %}{{ g.price | money }}</span>
              </span>
            </a>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="ar__panel" style="margin-top:18px">
        <div class="ar__ph mp-cond">More from the blog</div>
        {%- for r in blog.articles limit: 5 -%}
          {%- unless r.id == article.id -%}
            <a class="ar__game" href="{{ r.url }}"><span style="flex:1"><span class="ar__gn mp-cond">{{ r.title }}</span><span class="ar__gm">{{ r.published_at | date: '%-d %b' }}</span></span></a>
          {%- endunless -%}
        {%- endfor -%}
      </div>
    </aside>
  </div>

  {%- assign related = blog.articles -%}
  {%- if related.size > 1 -%}
    <div class="ar__keep">
      <div class="ar__kh mp-cond">Keep reading</div>
      <div class="ar__kgrid">
        {%- assign shown = 0 -%}
        {%- for r in related -%}
          {%- if r.id == article.id -%}{%- continue -%}{%- endif -%}
          {%- if shown >= 3 -%}{%- break -%}{%- endif -%}
          {%- assign shown = shown | plus: 1 -%}
          {%- assign rwords = r.content | strip_html | split: ' ' | size -%}
          {%- assign rread = rwords | divided_by: 200 | plus: 1 -%}
          <a class="ar__kcard" href="{{ r.url }}">
            <div class="ar__kimg"{% if r.image %} style="background-image:url('{{ r.image | image_url: width: 600 }}')"{% endif %}>
              {%- if r.tags.first -%}<span class="ar__ktag mp-cond">{{ r.tags.first }}</span>{%- endif -%}
            </div>
            <div class="ar__kbody">
              <div class="ar__kt mp-cond">{{ r.title }}</div>
              <div class="ar__km">{{ r.author }} · {{ rread }} min · {{ r.published_at | date: '%-d %b' }}</div>
            </div>
          </a>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</section>

<script>
  (function () {
    var root = document.querySelector('.mp-ar-{{ section.id }}');
    if (!root) return;
    var btn = root.querySelector('[data-share]');
    if (btn) btn.addEventListener('click', function () {
      var data = { title: {{ article.title | json }}, url: window.location.href };
      if (navigator.share) { navigator.share(data).catch(function () {}); }
      else if (navigator.clipboard) { navigator.clipboard.writeText(window.location.href); btn.textContent = '✓ Link copied'; }
    });
  })();
</script>

{% schema %}
{
  "name": "MP Article",
  "settings": [
    { "type": "text", "id": "author_role", "label": "Author role", "default": "MPGames Editorial" },
    { "type": "textarea", "id": "author_bio", "label": "Author bio", "default": "The MPGames editorial team reviews and ranks tabletop games — and is always one more game night away from a new favourite." }
  ],
  "enabled_on": { "templates": ["article"] },
  "presets": [
    { "name": "MP Article" }
  ]
}
{% endschema %}
