{%- comment -%}
  MPGames editorial / blog cards. Imported from Claude Design.
{%- endcomment -%}

{%- style -%}
  .mp-ed-{{ section.id }} .mp-ed__pad { padding: 24px 28px 8px; }
  .mp-ed-{{ section.id }} .mp-ed__head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 14px; }
  .mp-ed-{{ section.id }} .mp-ed__title { font-size: 20px; font-weight: 700; color: #16323f; }
  .mp-ed-{{ section.id }} .mp-ed__all { font-size: 12.5px; color: #f2872f; font-weight: 600; text-decoration: none; }
  .mp-ed-{{ section.id }} .mp-ed__grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; }
  .mp-ed-{{ section.id }} .mp-ed__card { border: 1px solid #e7e0d4; border-radius: 11px; overflow: hidden; background: #fff; text-decoration: none; display: block; }
  .mp-ed-{{ section.id }} .mp-ed__media {
    aspect-ratio: 16 / 10; display: flex; align-items: center; justify-content: center;
    font: 11px ui-monospace, monospace; color: #a39c92; background-size: cover; background-position: center;
    background-color: #efece6;
    background-image: repeating-linear-gradient(45deg,#efece6,#efece6 9px,#e6e2da 9px,#e6e2da 18px);
  }
  .mp-ed-{{ section.id }} .mp-ed__media--img { background-repeat: no-repeat; }
  .mp-ed-{{ section.id }} .mp-ed__body { padding: 14px 15px 16px; }
  .mp-ed-{{ section.id }} .mp-ed__tag { font-size: 11.5px; font-weight: 600; color: #f2872f; letter-spacing: .4px; }
  .mp-ed-{{ section.id }} .mp-ed__h { font-size: 16px; font-weight: 600; color: #16323f; margin-top: 5px; line-height: 1.25; }
  .mp-ed-{{ section.id }} .mp-ed__meta { font-size: 12px; color: #8a8278; margin-top: 6px; }
  @media (max-width: 749px) { .mp-ed-{{ section.id }} .mp-ed__grid { grid-template-columns: 1fr; } .mp-ed-{{ section.id }} .mp-ed__pad { padding: 24px 16px 8px; } }
{%- endstyle -%}

{%- assign ed_blog = blogs[section.settings.blog] -%}
{%- if section.settings.blog != blank and ed_blog.articles_count > 0 -%}
<div class="mp-cream mp-ed-{{ section.id }}">
  <div class="mp-col">
    <div class="mp-ed__pad">
      <div class="mp-ed__head">
        <div class="mp-ed__title mp-cond">{{ section.settings.title }}</div>
        {%- if section.settings.link_label != blank -%}
          <a class="mp-ed__all" href="{{ section.settings.link_url | default: '#' }}">{{ section.settings.link_label }} &#8594;</a>
        {%- endif -%}
      </div>
      <div class="mp-ed__grid">
        {%- for article in ed_blog.articles limit: section.settings.articles_to_show -%}
          {%- liquid
            assign words = article.content | strip_html | split: ' ' | size
            assign read = words | divided_by: 200 | plus: 1
          -%}
          <a class="mp-ed__card" href="{{ article.url }}">
            <div class="mp-ed__media"{% if article.image %} style="background-image:url('{{ article.image | image_url: width: 600 }}')"{% endif %}>{% unless article.image %}article image{% endunless %}</div>
            <div class="mp-ed__body">
              <div class="mp-ed__tag mp-cond">{{ article.tags.first | default: 'Article' }}</div>
              <div class="mp-ed__h mp-cond">{{ article.title }}</div>
              <div class="mp-ed__meta">{{ read }} min read · {{ article.published_at | date: '%b %Y' }}</div>
            </div>
          </a>
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "MP Editorial",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "From the MPGames blog" },
    { "type": "blog", "id": "blog", "label": "Blog", "info": "Section is hidden unless the selected blog has published articles." },
    { "type": "range", "id": "articles_to_show", "min": 3, "max": 6, "step": 1, "label": "Articles to show", "default": 3 },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "All articles" },
    { "type": "url", "id": "link_url", "label": "Link URL" }
  ],
  "presets": [
    { "name": "MP Editorial" }
  ]
}
{% endschema %}
