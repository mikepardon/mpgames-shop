{%- comment -%}
  MPGames policy page (Privacy, Refund, Terms, Shipping). Renders the Shopify
  policy content (page.title / page.content) in a wider, on-brand reading column.
  Wired via templates/policy.json.
{%- endcomment -%}

{%- style -%}
  .mp-pol-{{ section.id }} { background: #f4efe6; font-family: 'Barlow', ui-sans-serif, system-ui, sans-serif; color: #16323f; }
  .mp-pol-{{ section.id }} .pol__wrap { max-width: 880px; margin: 0 auto; padding: 40px 28px 56px; }
  .mp-pol-{{ section.id }} .pol__crumb { font-size: 12.5px; color: #9b948a; margin-bottom: 14px; }
  .mp-pol-{{ section.id }} .pol__crumb a { color: inherit; text-decoration: none; }
  .mp-pol-{{ section.id }} .pol__h1 { font-size: 38px; font-weight: 700; line-height: 1.1; margin: 0 0 22px; }
  .mp-pol-{{ section.id }} .pol__rte { font-size: 15.5px; line-height: 1.75; color: #3a4750; }
  .mp-pol-{{ section.id }} .pol__rte h2 { font-size: 22px; font-weight: 700; color: #16323f; margin: 34px 0 10px; }
  .mp-pol-{{ section.id }} .pol__rte h3 { font-size: 17px; font-weight: 700; color: #16323f; margin: 26px 0 8px; }
  .mp-pol-{{ section.id }} .pol__rte p { margin: 0 0 16px; }
  .mp-pol-{{ section.id }} .pol__rte ul, .mp-pol-{{ section.id }} .pol__rte ol { margin: 0 0 16px; padding-left: 22px; }
  .mp-pol-{{ section.id }} .pol__rte li { margin-bottom: 7px; }
  .mp-pol-{{ section.id }} .pol__rte a { color: #f2872f; text-decoration: underline; }
  .mp-pol-{{ section.id }} .pol__rte strong { color: #16323f; }
  .mp-pol-{{ section.id }} .pol__rte table { width: 100%; border-collapse: collapse; margin: 0 0 16px; }
  .mp-pol-{{ section.id }} .pol__rte th, .mp-pol-{{ section.id }} .pol__rte td { border: 1px solid #e2ddd1; padding: 9px 12px; text-align: left; }
  @media (max-width: 749px) {
    .mp-pol-{{ section.id }} .pol__wrap { padding: 28px 16px 40px; }
    .mp-pol-{{ section.id }} .pol__h1 { font-size: 30px; }
  }
  /* Widen Shopify's built-in policy wrapper (injected outside this section) */
  .shopify-policy__container { max-width: 800px; }
{%- endstyle -%}

<section class="mp-pol-{{ section.id }}">
  <div class="pol__wrap">
    <div class="pol__crumb"><a href="{{ routes.root_url }}">Home</a> <span>/</span> {{ page.title }}</div>
    <h1 class="pol__h1 mp-cond">{{ page.title }}</h1>
    <div class="pol__rte rte">{{ page.content }}</div>
  </div>
</section>

{% schema %}
{
  "name": "MP Policy",
  "settings": []
}
{% endschema %}
