{%- comment -%}
  MPGames utility bar — top dark strip above the main header.
  Imported from Claude Design "MPGames Homepage".
{%- endcomment -%}

{%- style -%}
  .mp-ub-{{ section.id }} {
    background: #0d2630;
    font-family: 'Barlow', ui-sans-serif, system-ui, sans-serif;
  }
  .mp-ub-{{ section.id }} .mp-ub__in {
    width: 100%;
    color: #9fb4bd;
    font-size: 12px;
    padding: 7px 28px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }
  .mp-ub-{{ section.id }} .mp-ub__links {
    display: flex;
    gap: 18px;
    align-items: center;
  }
  .mp-ub-{{ section.id }} a {
    color: inherit;
    text-decoration: none;
  }
  .mp-ub-{{ section.id }} .mp-ub__cur { color: #fff; }
  .mp-ub-{{ section.id }} .mp-ub__locform { display: inline-flex; margin: 0; }
  .mp-ub-{{ section.id }} .mp-ub__cursel {
    background: transparent; color: #fff; border: 0; font-family: inherit; font-size: 12px;
    cursor: pointer; padding: 0 2px; outline: 0;
  }
  .mp-ub-{{ section.id }} .mp-ub__cursel option { color: #16323f; }
  @media (max-width: 749px) {
    .mp-ub-{{ section.id }} .mp-ub__in { font-size: 11px; padding: 6px 16px; }
    .mp-ub-{{ section.id }} .mp-ub__links a { display: none; }
  }
{%- endstyle -%}

<div class="mp-ub-{{ section.id }}">
  <div class="mp-ub__in">
    <span>&#9733; {{ section.settings.promo_text }}</span>
    <span class="mp-ub__links">
      {%- if section.settings.link_1_label != blank and section.settings.link_1_url != blank -%}<a href="{{ section.settings.link_1_url }}">{{ section.settings.link_1_label }}</a>{%- endif -%}
      {%- if section.settings.link_2_label != blank and section.settings.link_2_url != blank -%}<a href="{{ section.settings.link_2_url }}">{{ section.settings.link_2_label }}</a>{%- endif -%}
      {%- if section.settings.link_3_label != blank and section.settings.link_3_url != blank -%}<a href="{{ section.settings.link_3_url }}">{{ section.settings.link_3_label }}</a>{%- endif -%}
      {%- if localization.available_currencies.size > 1 -%}
        {%- form 'localization', class: 'mp-ub__locform' -%}
          <select class="mp-ub__cursel" name="currency_code" aria-label="Currency" onchange="this.form.submit()">
            {%- for currency in localization.available_currencies -%}
              <option value="{{ currency.iso_code }}"{% if currency.iso_code == localization.currency.iso_code %} selected{% endif %}>{{ currency.iso_code }} {{ currency.symbol }}</option>
            {%- endfor -%}
          </select>
        {%- endform -%}
      {%- else -%}
        <span class="mp-ub__cur">{{ localization.currency.iso_code }} {{ localization.currency.symbol }}</span>
      {%- endif -%}
    </span>
  </div>
</div>

{% schema %}
{
  "name": "MP Utility bar",
  "settings": [
    { "type": "text", "id": "promo_text", "label": "Promo text", "default": "Free UK delivery over £50 · Next working day dispatch" },
    { "type": "text", "id": "link_1_label", "label": "Link 1 label", "default": "Help" },
    { "type": "url", "id": "link_1_url", "label": "Link 1 URL" },
    { "type": "text", "id": "link_2_label", "label": "Link 2 label", "default": "Track order" },
    { "type": "url", "id": "link_2_url", "label": "Link 2 URL" },
    { "type": "text", "id": "link_3_label", "label": "Link 3 label", "default": "Trade enquiries" },
    { "type": "url", "id": "link_3_url", "label": "Link 3 URL" }
  ],
  "enabled_on": { "groups": ["header"] }
}
{% endschema %}
