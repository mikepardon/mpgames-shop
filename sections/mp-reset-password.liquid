{%- comment -%}
  MPGames reset password — sets a new password from an emailed reset link.
  Uses the real Shopify `reset_customer_password` form.
{%- endcomment -%}

{%- style -%}
  .mp-rp-{{ section.id }} { background: #f4efe6; font-family: 'Barlow', ui-sans-serif, system-ui, sans-serif; color: #16323f; }
  .mp-rp-{{ section.id }} .rp__wrap { max-width: 440px; margin: 0 auto; padding: 48px 28px 60px; }
  .mp-rp-{{ section.id }} .rp__card { background: #fff; border: 1px solid #e7ddcb; border-radius: 14px; padding: 34px 34px 38px; box-shadow: 0 1px 3px rgba(20,40,50,.05); }
  .mp-rp-{{ section.id }} .rp__h { font-size: 24px; font-weight: 700; line-height: 1.15; }
  .mp-rp-{{ section.id }} .rp__sub { font-size: 13px; color: #8a8278; margin-top: 6px; }
  .mp-rp-{{ section.id }} .rp__field { margin-top: 16px; }
  .mp-rp-{{ section.id }} .rp__label { font-size: 12.5px; font-weight: 600; color: #4a443c; margin-bottom: 6px; }
  .mp-rp-{{ section.id }} .rp__input { width: 100%; box-sizing: border-box; border: 1px solid #d8d4cc; border-radius: 8px; padding: 12px 14px; font-size: 13.5px; background: #fbfaf7; font-family: inherit; color: #16323f; }
  .mp-rp-{{ section.id }} .rp__btn { width: 100%; background: #f2872f; color: #fff; text-align: center; font-size: 15px; font-weight: 700; padding: 13px; border-radius: 9px; margin-top: 22px; border: 0; cursor: pointer; font-family: inherit; }
  .mp-rp-{{ section.id }} .rp__errors { background: #fdecea; border: 1px solid #f3c0bb; color: #9a3b2e; border-radius: 8px; padding: 10px 13px; font-size: 12.5px; margin-top: 16px; }
  .mp-rp-{{ section.id }} .rp__errors ul { margin: 6px 0 0; padding-left: 18px; }
  .mp-rp-{{ section.id }} .rp__errors a { color: #9a3b2e; }
{%- endstyle -%}

<div class="mp-rp-{{ section.id }}">
  <div class="rp__wrap">
    <div class="rp__card">
      <div class="rp__h mp-cond">Reset your password</div>
      <div class="rp__sub">Choose a new password for your MPGames account.</div>
      {%- form 'reset_customer_password' -%}
        {%- if form.errors -%}
          <div class="rp__errors">
            There was a problem resetting your password:
            <ul>
              {%- for field in form.errors -%}
                <li>
                  {%- if field == 'form' -%}
                    {{ form.errors.messages[field] }}
                  {%- else -%}
                    <a href="#{{ field }}">{{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}</a>
                  {%- endif -%}
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
        <div class="rp__field">
          <div class="rp__label">New password</div>
          <input type="password" name="customer[password]" id="password" class="rp__input" autocomplete="new-password" placeholder="New password" required>
        </div>
        <div class="rp__field">
          <div class="rp__label">Confirm password</div>
          <input type="password" name="customer[password_confirmation]" id="password_confirmation" class="rp__input" autocomplete="new-password" placeholder="Re-enter your password" required>
        </div>
        <button type="submit" class="rp__btn mp-cond">Reset password</button>
      {%- endform -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "MP Reset password",
  "settings": [],
  "presets": [ { "name": "MP Reset password" } ]
}
{% endschema %}
